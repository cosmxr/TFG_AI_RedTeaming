@* ============================================================
   Views/Metricas/Evolucion.cshtml — Evolución temporal
   AI Red Teaming Platform - TFG Ingeniería Informática
   v6.0
   ============================================================ *@

@using TFG_Portal.Models
@{
    ViewData["Title"] = "Evolución";
    var proyecto   = ViewData["Proyecto"]    as Proyecto;
    var porDiaJson = ViewData["PorDiaJson"]  as string ?? "[]";
    var porSevJson = ViewData["PorSevJson"]  as string ?? "[]";
    var porTipoJson = ViewData["PorTipoJson"] as string ?? "[]";
    var apiActiva  = ViewData["ApiEstado"]   as bool? ?? false;
}

@* ── Cabecera ── *@
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
    <div class="d-flex align-items-center gap-3">
        <div class="page-header-icon">
            <i class="fa-solid fa-chart-line"></i>
        </div>
        <div>
            <h1 class="page-title">Evolución de Auditorías</h1>
            <p class="page-subtitle">
                Actividad, severidad y tipos de ataque
                @if (proyecto != null)
                {
                    <span class="ms-2">
                        · <strong style="color:var(--color-green);">@proyecto.Nombre</strong>
                    </span>
                }
            </p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Metricas" asp-action="Exportar"
           class="btn-redteam-secondary"
           title="Descargar CSV completo">
            <i class="fa-solid fa-file-csv me-1"></i> Exportar CSV
        </a>
        <a asp-controller="Metricas" asp-action="Comparativa"
           class="btn-redteam-secondary">
            <i class="fa-solid fa-chart-bar me-1"></i> Comparativa
        </a>
    </div>
</div>

@if (porDiaJson == "[]" && porSevJson == "[]" && porTipoJson == "[]")
{
    <div class="card-redteam">
        <div class="empty-state-redteam" style="min-height:280px;">
            <i class="fa-solid fa-chart-line fa-3x mb-4" style="opacity:0.2;"></i>
            <p style="font-size:0.95rem; color:var(--color-text-muted);">
                No hay datos de actividad todavía.
            </p>
            <a asp-controller="Auditoria" asp-action="Benchmark"
               class="btn-redteam-primary mt-3">
                <i class="fa-solid fa-flask me-1"></i> Lanzar benchmark
            </a>
        </div>
    </div>
}
else
{
    @* ── Fila superior: actividad 7 días + donut severidad ── *@
    <div class="row g-3 mb-4">

        <div class="col-xl-7">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-chart-line me-2"></i>
                        ACTIVIDAD — ÚLTIMOS 7 DÍAS
                    </span>
                </div>
                @if (porDiaJson == "[]")
                {
                    <div class="empty-state-redteam" style="min-height:200px;">
                        <p style="color:var(--color-text-muted);">
                            Sin actividad en los últimos 7 días
                        </p>
                    </div>
                }
                else
                {
                    <div style="position:relative; height:220px; padding:12px 4px 4px;">
                        <canvas id="chartLinea"></canvas>
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-chart-pie me-2"></i>
                        DISTRIBUCIÓN DE SEVERIDAD
                    </span>
                </div>
                @if (porSevJson == "[]")
                {
                    <div class="empty-state-redteam" style="min-height:160px;">
                        <p style="color:var(--color-text-muted);">Sin vulnerabilidades</p>
                    </div>
                }
                else
                {
                    <div style="position:relative; height:160px; padding:12px 4px 4px;">
                        <canvas id="chartDonut"></canvas>
                    </div>
                    <div id="legend-donut" class="donut-legend"></div>
                }
            </div>
        </div>

    </div>

    @* ── Ataques por tipo ── *@
    <div class="card-redteam">
        <div class="card-redteam-header">
            <span class="card-redteam-title">
                <i class="fa-solid fa-chart-bar me-2"></i>
                TOTAL DE ATAQUES POR TIPO
            </span>
            <div class="d-flex gap-2">
                <span style="font-family:var(--font-code); font-size:0.62rem;
                              padding:2px 7px; border-radius:3px;
                              background:rgba(0,255,65,0.08); border:1px solid rgba(0,255,65,0.25);
                              color:var(--color-green);">
                    ■ Clásico
                </span>
                <span style="font-family:var(--font-code); font-size:0.62rem;
                              padding:2px 7px; border-radius:3px;
                              background:rgba(255,170,0,0.08); border:1px solid rgba(255,170,0,0.25);
                              color:#ffaa00;">
                    ■ AI Red Team
                </span>
            </div>
        </div>
        @if (porTipoJson == "[]")
        {
            <div class="empty-state-redteam" style="min-height:160px;">
                <p style="color:var(--color-text-muted);">No hay ataques registrados</p>
            </div>
        }
        else
        {
            <div style="position:relative; height:240px; padding:12px 4px 4px;">
                <canvas id="chartBarras"></canvas>
            </div>
        }
    </div>
}

@* Data JSON *@
<script id="data-por-dia"  type="application/json">@Html.Raw(porDiaJson)</script>
<script id="data-por-sev"  type="application/json">@Html.Raw(porSevJson)</script>
<script id="data-por-tipo" type="application/json">@Html.Raw(porTipoJson)</script>

@section Styles {
<style>
.donut-legend {
    display:flex; justify-content:center; gap:16px;
    flex-wrap:wrap; padding:8px 16px 12px;
}
.donut-legend-item {
    display:flex; align-items:center; gap:6px;
    font-size:0.72rem; color:var(--color-text-muted);
}
.donut-legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
</style>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
(function () {
    const gridCol = 'rgba(255,255,255,0.06)';
    const textCol = '#666d76';
    const green   = '#00ff41';
    const yellow  = '#ffaa00';
    const red     = '#dc3545';
    const blue    = '#4488ff';
    const aiTypes = new Set(['PROMPT_INJECTION','JAILBREAK','SYSTEM_PROMPT_LEAKAGE',
                             'DATA_EXTRACTION','CONTEXT_MANIPULATION','INDIRECT_INJECTION']);
    const labelMap = {
        PROMPT_INJECTION:'PI', JAILBREAK:'JB', SYSTEM_PROMPT_LEAKAGE:'SPL',
        DATA_EXTRACTION:'DE', CONTEXT_MANIPULATION:'CM', INDIRECT_INJECTION:'II',
        XSS:'XSS', SQLI:'SQLi', LFI:'LFI', CSRF:'CSRF'
    };

    Chart.defaults.color       = textCol;
    Chart.defaults.font.family = "'JetBrains Mono', monospace";
    Chart.defaults.font.size   = 11;

    function readJson(id) {
        try { return JSON.parse(document.getElementById(id)?.textContent || '[]'); }
        catch { return []; }
    }

    // ── Línea actividad ─────────────────────────────────────
    const dataDia = readJson('data-por-dia');
    if (dataDia.length && document.getElementById('chartLinea')) {
        new Chart(document.getElementById('chartLinea'), {
            type: 'line',
            data: {
                labels: dataDia.map(d => d.Fecha),
                datasets: [{
                    label: 'Ataques',
                    data: dataDia.map(d => d.Total),
                    borderColor: green,
                    backgroundColor: 'rgba(0,255,65,0.08)',
                    borderWidth: 2,
                    pointBackgroundColor: green,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: gridCol }, ticks: { color: textCol } },
                    y: { grid: { color: gridCol }, ticks: { color: textCol, stepSize: 1 },
                         beginAtZero: true }
                }
            }
        });
    }

    // ── Donut severidad ──────────────────────────────────────
    const dataSev = readJson('data-por-sev');
    if (dataSev.length && document.getElementById('chartDonut')) {
        const sevColors = { Alta: red, Media: yellow, Baja: blue };
        const colors    = dataSev.map(d => sevColors[d.Severidad] || '#888');

        new Chart(document.getElementById('chartDonut'), {
            type: 'doughnut',
            data: {
                labels: dataSev.map(d => d.Severidad),
                datasets: [{
                    data: dataSev.map(d => d.Total),
                    backgroundColor: colors.map(c => c + '33'),
                    borderColor: colors,
                    borderWidth: 2,
                    hoverOffset: 6,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: { label: ctx => ` ${ctx.label}: ${ctx.parsed}` }
                    }
                }
            }
        });

        const legend = document.getElementById('legend-donut');
        if (legend) {
            dataSev.forEach((d, i) => {
                const el = document.createElement('div');
                el.className = 'donut-legend-item';
                el.innerHTML =
                    `<span class="donut-legend-dot" style="background:${colors[i]};"></span>` +
                    `<span>${d.Severidad}: <strong>${d.Total}</strong></span>`;
                legend.appendChild(el);
            });
        }
    }

    // ── Barras por tipo ──────────────────────────────────────
    const dataTipo = readJson('data-por-tipo');
    if (dataTipo.length && document.getElementById('chartBarras')) {
        const colores = dataTipo.map(d => aiTypes.has(d.TipoAtaque) ? yellow : green);

        new Chart(document.getElementById('chartBarras'), {
            type: 'bar',
            data: {
                labels: dataTipo.map(d => labelMap[d.TipoAtaque] || d.TipoAtaque),
                datasets: [{
                    label: 'Total ataques',
                    data: dataTipo.map(d => d.Total),
                    backgroundColor: colores.map(c => c + '33'),
                    borderColor: colores,
                    borderWidth: 1,
                    borderRadius: 3,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: gridCol }, ticks: { color: textCol } },
                    y: { grid: { color: gridCol }, ticks: { color: textCol, stepSize: 1 },
                         beginAtZero: true }
                }
            }
        });
    }
}());
</script>
}
