@* ============================================================
   Views/Metricas/Comparativa.cshtml
   AI Red Teaming Platform · TFG Ingeniería Informática
   v7.0 — comparativa multi-modelo completa
   Gráficas: heatmap · radar · barras agrupadas ·
             tiempo de respuesta · distribución severidades
   ============================================================ *@

@using TFG_Portal.Models
@{
    ViewData["Title"] = "Comparativa de Modelos";
    var proyecto  = ViewData["Proyecto"]  as Proyecto;
    var modelos   = ViewData["Modelos"]   as List<string>  ?? new();
    var tipos     = ViewData["Tipos"]     as List<string>  ?? new();
    var indice    = ViewData["Indice"]    as Dictionary<(string, string), ComparativaModelos>
                    ?? new();
    var ranking   = ViewData["Ranking"]   as List<RobustezItem> ?? new();

    // Abreviaturas para cabeceras
    string Abrev(string t) => t switch {
        "PROMPT_INJECTION"    => "PI",
        "INDIRECT_INJECTION"  => "II",
        "CONTEXT_MANIPULATION"=> "CM",
        "SYSTEM_PROMPT_LEAKAGE"=> "SPL",
        "DATA_EXTRACTION"     => "DE",
        "JAILBREAK"           => "JB",
        _                     => t
    };

    // Color de celda heatmap
    string HeatBg(double v) => v switch {
        <= 0  => "rgba(0,255,65,0.08)",
        <= 25 => "rgba(0,255,65,0.18)",
        <= 50 => "rgba(255,170,0,0.25)",
        <= 75 => "rgba(220,53,69,0.35)",
        _     => "rgba(220,53,69,0.62)"
    };
    string HeatFg(double v) => v > 50 ? "#fff" : "var(--color-text)";

    // Tipos WEB vs AI
    var tiposWeb = new[] { "XSS","SQLI","LFI","CSRF" };
    bool EsWeb(string t) => tiposWeb.Contains(t);

    // KPI strip — calculados aquí para evitar @{} anidado en else
    int totalAtaquesGlobal = indice.Values.Sum(f => f.TotalAtaques);
    int totalVulnGlobal    = indice.Values.Sum(f => f.TotalVulnerables);
    double tasaGlobal      = totalAtaquesGlobal > 0
        ? Math.Round((double)totalVulnGlobal / totalAtaquesGlobal * 100, 1) : 0;
    int totalCanaryGlobal  = ranking.Sum(r => r.TotalCanary);
    double mejorRobustez   = ranking.Any() ? ranking.First().PorcentajeRobustez : 0;

    var tasasPorModelo = modelos.Select(m => new {
        Modelo = m,
        Tasa   = tipos.Any(t => indice.ContainsKey((m, t)))
                    ? tipos.Where(t => indice.ContainsKey((m, t)))
                           .Average(t => (double)indice[(m, t)].TasaVulnerabilidad)
                    : 100.0
    }).OrderBy(x => x.Tasa).ToList();
    string modeloMasRobusto = tasasPorModelo.FirstOrDefault()?.Modelo ?? "—";
}

@* ─── CABECERA ──────────────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
    <div class="d-flex align-items-center gap-3">
        <div class="page-header-icon">
            <i class="fa-solid fa-chart-bar"></i>
        </div>
        <div>
            <h1 class="page-title">Comparativa de Modelos</h1>
            <p class="page-subtitle">
                Análisis comparativo de vulnerabilidad, robustez y rendimiento
                @if (proyecto != null)
                {
                    <span class="ms-2">·
                        <strong style="color:var(--color-green);">@proyecto.Nombre</strong>
                    </span>
                }
            </p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Metricas" asp-action="Ranking"
           class="btn-redteam-secondary">
            <i class="fa-solid fa-trophy me-1"></i> Ranking
        </a>
        <a asp-controller="Auditoria" asp-action="Benchmark"
           class="btn-redteam-primary">
            <i class="fa-solid fa-flask me-1"></i> Nuevo Benchmark
        </a>
    </div>
</div>

@if (!modelos.Any())
{
    <div class="card-redteam">
        <div class="empty-state-redteam" style="min-height:280px;">
            <i class="fa-solid fa-chart-bar fa-3x mb-4" style="opacity:0.2;"></i>
            <p style="font-size:0.95rem; color:var(--color-text-muted);">
                No hay datos de comparativa todavía.
            </p>
            <p style="font-size:0.82rem; color:var(--color-text-dim); max-width:400px;">
                Lanza auditorías benchmark contra al menos un modelo para ver la comparativa.
            </p>
            <a asp-controller="Auditoria" asp-action="Benchmark"
               class="btn-redteam-primary mt-3">
                <i class="fa-solid fa-flask me-1"></i> Lanzar benchmark
            </a>
        </div>
    </div>
}
else
{
    @* ─── KPI STRIP ──────────────────────────────────────── *@
    <div class="cmp-kpi-strip mb-4">
        <div class="cmp-kpi">
            <span class="cmp-kpi-val" style="color:var(--color-green);">@modelos.Count</span>
            <span class="cmp-kpi-lbl">Modelos</span>
        </div>
        <div class="cmp-kpi">
            <span class="cmp-kpi-val">@totalAtaquesGlobal</span>
            <span class="cmp-kpi-lbl">Ataques totales</span>
        </div>
        <div class="cmp-kpi">
            <span class="cmp-kpi-val" style="color:@(tasaGlobal >= 50 ? "#dc3545" : "#ffaa00");">
                @tasaGlobal.ToString("0.0")%
            </span>
            <span class="cmp-kpi-lbl">Tasa vuln. global</span>
        </div>
        <div class="cmp-kpi">
            <span class="cmp-kpi-val" style="color:#ff6b6b;">@totalCanaryGlobal</span>
            <span class="cmp-kpi-lbl">Canary hits</span>
        </div>
        <div class="cmp-kpi">
            <span class="cmp-kpi-val" style="color:var(--color-green);">@mejorRobustez.ToString("0.0")%</span>
            <span class="cmp-kpi-lbl">Mejor robustez</span>
        </div>
        <div class="cmp-kpi" style="max-width:260px;">
            <span class="cmp-kpi-val mono" style="font-size:0.72rem; color:var(--color-green);">
                @(modeloMasRobusto.Length > 26 ? modeloMasRobusto[..26] + "…" : modeloMasRobusto)
            </span>
            <span class="cmp-kpi-lbl">Modelo más robusto</span>
        </div>
    </div>

    @* ─── FILA 1: HEATMAP + RADAR ────────────────────────── *@
    <div class="row g-4 mb-4">

        @* HEATMAP *@
        <div class="col-xl-7">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-table-cells me-2"></i>
                        HEATMAP — TASA DE VULNERABILIDAD (%)
                    </span>
                    <div class="hm-legend">
                        <span class="hm-safe">0%</span>
                        <div class="hm-legend-bar"></div>
                        <span class="hm-danger">100%</span>
                    </div>
                </div>
                <div class="table-responsive-redteam">
                    <table class="table-redteam heatmap-table">
                        <thead>
                            <tr>
                                <th class="hm-modelo-col">Modelo</th>
                                @foreach (var tipo in tipos)
                                {
                                    <th class="text-center hm-tipo-col"
                                        title="@tipo">
                                        <span class="hm-tipo-label @(EsWeb(tipo) ? "hm-tipo-web" : "hm-tipo-ai")">
                                            @Abrev(tipo)
                                        </span>
                                    </th>
                                }
                                <th class="text-center" style="width:64px; font-size:0.62rem;">
                                    MEDIA
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var modelo in modelos)
                            {
                                var tasasModelo = tipos
                                    .Where(t => indice.ContainsKey((modelo, t)))
                                    .Select(t => (double)indice[(modelo, t)].TasaVulnerabilidad)
                                    .ToList();
                                var mediaModelo = tasasModelo.Any()
                                    ? Math.Round(tasasModelo.Average(), 1) : 0.0;

                                <tr>
                                    <td class="hm-modelo-nombre">
                                        <span class="mono"
                                              style="font-size:0.68rem; color:var(--color-text-muted);">
                                            @(modelo.Length > 30 ? modelo[..30] + "…" : modelo)
                                        </span>
                                    </td>
                                    @foreach (var tipo in tipos)
                                    {
                                        @if (indice.TryGetValue((modelo, tipo), out var fila))
                                        {
                                            var tasa = (double)fila.TasaVulnerabilidad;
                                            <td class="text-center hm-cell"
                                                style="background:@HeatBg(tasa);"
                                                title="@tipo: @tasa% (@fila.TotalVulnerables / @fila.TotalAtaques)">
                                                <span class="hm-cell-val"
                                                      style="color:@HeatFg(tasa);">
                                                    @tasa.ToString("0")%
                                                </span>
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="text-center hm-cell hm-cell-empty">
                                                <span style="color:var(--color-text-dim);">—</span>
                                            </td>
                                        }
                                    }
                                    <td class="text-center">
                                        <span class="hm-media"
                                              style="color:@(mediaModelo >= 50 ? "#dc3545" : "var(--color-green)");">
                                            @mediaModelo.ToString("0.0")%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex gap-3 px-3 pb-3 mt-1 flex-wrap">
                    <div class="d-flex align-items-center gap-2">
                        <span class="hm-tipo-label hm-tipo-web" style="font-size:0.6rem;">WEB</span>
                        <span style="font-size:0.7rem; color:var(--color-text-dim);">XSS · SQLi · LFI · CSRF</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="hm-tipo-label hm-tipo-ai" style="font-size:0.6rem;">AI</span>
                        <span style="font-size:0.7rem; color:var(--color-text-dim);">PI · JB · SPL · DE · CM · II</span>
                    </div>
                </div>
            </div>
        </div>

        @* RADAR CHART *@
        <div class="col-xl-5">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-spider me-2"></i>
                        PERFIL DE VULNERABILIDAD — RADAR
                    </span>
                </div>
                <div style="position:relative; height:300px; padding:16px 8px 8px;">
                    <canvas id="chartRadar"></canvas>
                </div>
                <p style="font-size:0.68rem; color:var(--color-text-dim);
                           text-align:center; padding:0 12px 12px;">
                    Superficie de ataque por categoría · cuanto mayor el área, más expuesto el modelo
                </p>
            </div>
        </div>
    </div>

    @* ─── FILA 2: BARRAS AGRUPADAS + TIEMPO RESPUESTA ─────── *@
    <div class="row g-4 mb-4">

        @* BARRAS AGRUPADAS *@
        <div class="col-xl-6">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-chart-bar me-2"></i>
                        TASA DE VULNERABILIDAD POR TIPO
                    </span>
                </div>
                <div style="position:relative; height:280px; padding:12px 4px 4px;">
                    <canvas id="chartBarras"></canvas>
                </div>
            </div>
        </div>

        @* TIEMPO DE RESPUESTA MEDIO *@
        <div class="col-xl-6">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-stopwatch me-2"></i>
                        TIEMPO MEDIO DE RESPUESTA (ms)
                    </span>
                </div>
                <div style="position:relative; height:280px; padding:12px 4px 4px;">
                    <canvas id="chartTiempo"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* ─── FILA 3: SEVERIDADES APILADAS + TABLA RESUMEN ───── *@
    <div class="row g-4 mb-4">

        @* BARRAS APILADAS SEVERIDAD *@
        <div class="col-xl-6">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-layer-group me-2"></i>
                        DISTRIBUCIÓN DE SEVERIDAD POR MODELO
                    </span>
                </div>
                <div style="position:relative; height:280px; padding:12px 4px 4px;">
                    <canvas id="chartSeveridad"></canvas>
                </div>
            </div>
        </div>

        @* TABLA RESUMEN NUMÉRICO *@
        <div class="col-xl-6">
            <div class="card-redteam h-100">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-table-list me-2"></i>
                        RESUMEN NUMÉRICO POR MODELO
                    </span>
                </div>
                <div class="table-responsive-redteam">
                    <table class="table-redteam" style="font-size:0.75rem;">
                        <thead>
                            <tr>
                                <th>Modelo</th>
                                <th class="text-center">Ataques</th>
                                <th class="text-center">Vuln.</th>
                                <th class="text-center">Tasa</th>
                                <th class="text-center" style="color:#dc3545;">Alta</th>
                                <th class="text-center" style="color:#ffaa00;">Media</th>
                                <th class="text-center">Canary</th>
                                <th class="text-center">T.med</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var modelo in modelos)
                            {
                                var filas = tipos
                                    .Where(t => indice.ContainsKey((modelo, t)))
                                    .Select(t => indice[(modelo, t)])
                                    .ToList();

                                int ataquesMod    = filas.Sum(f => f.TotalAtaques);
                                int vulnMod       = filas.Sum(f => f.TotalVulnerables);
                                double tasaMod    = ataquesMod > 0
                                    ? Math.Round((double)vulnMod / ataquesMod * 100, 1) : 0;
                                int altaMod       = filas.Sum(f => f.SeveridadAlta);
                                int mediaMod      = filas.Sum(f => f.SeveridadMedia);
                                var rankItem      = ranking.FirstOrDefault(r => r.ModeloAuditado == modelo);
                                int canaryMod     = rankItem?.TotalCanary ?? 0;
                                double? tmedMod   = filas.Any(f => f.TiempoMedio.HasValue)
                                    ? filas.Where(f => f.TiempoMedio.HasValue)
                                           .Average(f => f.TiempoMedio!.Value) : null;

                                <tr>
                                    <td>
                                        <span class="mono"
                                              style="font-size:0.66rem; color:var(--color-text-muted);">
                                            @(modelo.Length > 22 ? modelo[..22] + "…" : modelo)
                                        </span>
                                    </td>
                                    <td class="text-center mono">@ataquesMod</td>
                                    <td class="text-center mono">@vulnMod</td>
                                    <td class="text-center">
                                        <span class="mono"
                                              style="color:@(tasaMod >= 50 ? "#dc3545" : "var(--color-green)");">
                                            @tasaMod.ToString("0.0")%
                                        </span>
                                    </td>
                                    <td class="text-center mono" style="color:#dc3545;">@altaMod</td>
                                    <td class="text-center mono" style="color:#ffaa00;">@mediaMod</td>
                                    <td class="text-center mono" style="color:#ff6b6b;">@canaryMod</td>
                                    <td class="text-center mono" style="font-size:0.65rem; color:var(--color-text-dim);">
                                        @(tmedMod.HasValue ? $"{tmedMod.Value / 1000.0:0.1}s" : "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Leyenda de métricas *@
                <div class="info-box" style="margin:12px; border-radius:4px;">
                    <div class="info-box-icon" style="color:#a78bfa;">
                        <i class="fa-solid fa-circle-info"></i>
                    </div>
                    <div class="info-box-text" style="font-size:0.7rem;">
                        <strong>Vuln.</strong> = ataques donde fue_vulnerable = 1 ·
                        <strong>Canary</strong> = token de detección encontrado en respuesta ·
                        <strong>T.med</strong> = tiempo medio de respuesta del modelo auditado
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ─── FILA 4: RANKING LATERAL COMPLETO ───────────────── *@
    @if (ranking.Any())
    {
        <div class="card-redteam mb-4">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-trophy me-2" style="color:#ffaa00;"></i>
                    RANKING DE ROBUSTEZ — VISTA RÁPIDA
                </span>
                <a asp-controller="Metricas" asp-action="Ranking"
                   class="btn-redteam-secondary"
                   style="padding:3px 10px; font-size:0.72rem;">
                    Ver ranking completo
                </a>
            </div>
            <div style="padding:0 16px 16px; display:flex; gap:12px; flex-wrap:wrap;">
                @foreach (var item in ranking)
                {
                    <div class="rank-quick-card @(item.Posicion == 1 ? "rank-quick-gold" : "")">
                        <div class="rank-quick-pos">
                            @if (item.Posicion == 1)
                            { <i class="fa-solid fa-trophy" style="color:#ffaa00;"></i> }
                            else
                            { <span class="mono">#@item.Posicion</span> }
                        </div>
                        <div class="rank-quick-name mono">
                            @(item.ModeloAuditado.Length > 22
                                ? item.ModeloAuditado[..22] + "…"
                                : item.ModeloAuditado)
                        </div>
                        <div class="rank-quick-bar-wrap">
                            <div class="rank-quick-bar"
                                 style="width:@item.PorcentajeRobustez.ToString("F0")%;
                                        background:@(item.PorcentajeRobustez >= 70
                                            ? "var(--color-green)" : "#dc3545");"></div>
                        </div>
                        <div class="rank-quick-pct"
                             style="color:@(item.PorcentajeRobustez >= 70
                                 ? "var(--color-green)" : "#dc3545");">
                            @item.PorcentajeRobustez.ToString("0.0")%
                        </div>
                        <span class="@item.NivelCssClass" style="font-size:0.6rem;">
                            @item.NivelRobustez
                        </span>
                    </div>
                }
            </div>
        </div>
    }
}

@* ─── JSON DATA PARA CHART.JS ────────────────────────────── *@
<script id="data-comparativa" type="application/json">
    @Html.Raw(ViewData["ComparativaJson"] as string ?? "[]")
</script>
<script id="data-ranking" type="application/json">
    @Html.Raw(ViewData["RankingJson"] as string ?? "[]")
</script>

@section Styles {
<style>
/* ── KPI strip ── */
.cmp-kpi-strip {
    display:flex; gap:0; background:var(--color-bg-secondary);
    border:1px solid var(--color-border); border-radius:var(--radius);
    overflow:hidden;
}
.cmp-kpi {
    flex:1; display:flex; flex-direction:column; align-items:center;
    justify-content:center; gap:4px; padding:14px 10px;
    border-right:1px solid var(--color-border);
}
.cmp-kpi:last-child { border-right:none; }
.cmp-kpi-val {
    font-family:var(--font-code); font-size:1.35rem; font-weight:700;
    color:var(--color-text); line-height:1;
}
.cmp-kpi-lbl {
    font-size:0.62rem; color:var(--color-text-dim);
    text-transform:uppercase; letter-spacing:0.08em; text-align:center;
}

/* ── Heatmap ── */
.heatmap-table th, .heatmap-table td { padding:7px 5px !important; }
.hm-modelo-col  { min-width:150px; }
.hm-tipo-col    { min-width:52px; }
.hm-modelo-nombre { padding-left:12px !important; }
.hm-tipo-label {
    font-family:var(--font-code); font-size:0.57rem; font-weight:700;
    padding:2px 5px; border-radius:3px; display:inline-block;
    letter-spacing:0.04em; white-space:nowrap;
}
.hm-tipo-web { background:rgba(0,255,65,0.1); color:var(--color-green); border:1px solid rgba(0,255,65,0.25); }
.hm-tipo-ai  { background:rgba(255,170,0,0.1); color:#ffaa00; border:1px solid rgba(255,170,0,0.25); }
.hm-cell { transition:opacity 0.15s; }
.hm-cell:hover { opacity:0.75; }
.hm-cell-empty { background:var(--color-bg-tertiary) !important; }
.hm-cell-val   { font-family:var(--font-code); font-size:0.7rem; font-weight:600; }
.hm-media      { font-family:var(--font-code); font-size:0.78rem; font-weight:700; }
.hm-legend {
    display:flex; align-items:center; gap:5px;
    font-family:var(--font-code); font-size:0.6rem;
}
.hm-legend-bar {
    width:55px; height:7px; border-radius:4px;
    background:linear-gradient(90deg, rgba(0,255,65,0.3), rgba(220,53,69,0.6));
}
.hm-safe   { color:var(--color-green); }
.hm-danger { color:#dc3545; }

/* ── Rank quick cards ── */
.rank-quick-card {
    flex:1; min-width:160px; max-width:220px;
    background:var(--color-bg-secondary); border:1px solid var(--color-border);
    border-radius:var(--radius); padding:12px 14px;
    display:flex; flex-direction:column; gap:6px;
    margin-top:4px;
}
.rank-quick-gold {
    border-color:rgba(255,170,0,0.35) !important;
    background:rgba(255,170,0,0.04) !important;
}
.rank-quick-pos {
    font-family:var(--font-code); font-size:0.78rem; font-weight:700;
    color:var(--color-text-dim);
}
.rank-quick-name {
    font-size:0.69rem; color:var(--color-text-muted);
    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.rank-quick-bar-wrap {
    height:5px; background:var(--color-bg-tertiary);
    border-radius:3px; overflow:hidden;
}
.rank-quick-bar { height:100%; border-radius:3px; transition:width 0.4s; }
.rank-quick-pct {
    font-family:var(--font-code); font-size:0.82rem; font-weight:700;
}

/* ── Info box ── */
.info-box {
    display:flex; gap:10px; padding:10px 14px;
    background:rgba(167,139,250,0.06);
    border:1px solid rgba(167,139,250,0.2); border-radius:4px;
}
.info-box-icon { color:#a78bfa; font-size:0.85rem; flex-shrink:0; padding-top:1px; }
.info-box-text { font-size:0.75rem; color:var(--color-text-muted); line-height:1.5; }
.info-box-text strong { color:var(--color-text); }

/* ── Misc ── */
.empty-state-redteam {
    display:flex; flex-direction:column; align-items:center;
    justify-content:center; padding:32px 24px; text-align:center;
    color:var(--color-text-dim);
}
.empty-state-redteam i   { opacity:0.4; margin-bottom:12px; }
.empty-state-redteam p   { font-size:0.82rem; color:var(--color-text-muted); margin:0; line-height:1.6; }
</style>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
(function () {
    /* ── Paleta y defaults ── */
    const gridCol = 'rgba(255,255,255,0.06)';
    const textCol = '#666d76';
    const PALETTE = ['#00ff41','#ffaa00','#4488ff','#a78bfa','#ff6b6b','#00ccff','#ff9f40','#c9cb3f'];

    Chart.defaults.color       = textCol;
    Chart.defaults.font.family = "'JetBrains Mono', monospace";
    Chart.defaults.font.size   = 10;

    const raw     = JSON.parse(document.getElementById('data-comparativa')?.textContent || '[]');
    const ranking = JSON.parse(document.getElementById('data-ranking')?.textContent     || '[]');

    if (!raw.length) return;

    const modelos = [...new Set(raw.map(c => c.ModeloIa))];
    const tipos   = [...new Set(raw.map(c => c.TipoAtaque))];

    const abrev = {
        PROMPT_INJECTION:'PI', JAILBREAK:'JB', SYSTEM_PROMPT_LEAKAGE:'SPL',
        DATA_EXTRACTION:'DE', CONTEXT_MANIPULATION:'CM', INDIRECT_INJECTION:'II',
        XSS:'XSS', SQLI:'SQLi', LFI:'LFI', CSRF:'CSRF'
    };

    function getCell(modelo, tipo) {
        return raw.find(c => c.ModeloIa === modelo && c.TipoAtaque === tipo);
    }

    /* ── 1. RADAR ──────────────────────────────────────────── */
    const ctxRadar = document.getElementById('chartRadar');
    if (ctxRadar) {
        const datasets = modelos.map((m, i) => ({
            label: m.length > 22 ? m.substring(0, 22) + '…' : m,
            data: tipos.map(t => {
                const c = getCell(m, t);
                return c ? parseFloat(c.TasaVulnerabilidad) : 0;
            }),
            backgroundColor: PALETTE[i % PALETTE.length] + '22',
            borderColor:     PALETTE[i % PALETTE.length],
            pointBackgroundColor: PALETTE[i % PALETTE.length],
            borderWidth: 2,
            pointRadius: 3,
        }));

        new Chart(ctxRadar, {
            type: 'radar',
            data: { labels: tipos.map(t => abrev[t] || t), datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                scales: {
                    r: {
                        beginAtZero: true, max: 100,
                        ticks: {
                            display: false,
                            stepSize: 25,
                        },
                        grid:        { color: 'rgba(255,255,255,0.08)' },
                        angleLines:  { color: 'rgba(255,255,255,0.08)' },
                        pointLabels: { color: textCol, font: { size: 10, family:"'JetBrains Mono',monospace" } },
                    }
                },
                plugins: {
                    legend: {
                        display: true, position: 'bottom',
                        labels: { color: textCol, boxWidth: 10, padding: 12, font: { size: 10 } }
                    },
                    tooltip: {
                        callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.r?.toFixed(0)}%` }
                    }
                }
            }
        });
    }

    /* ── 2. BARRAS AGRUPADAS — tasa vuln por tipo ──────────── */
    const ctxBarras = document.getElementById('chartBarras');
    if (ctxBarras) {
        const datasets = modelos.map((m, i) => ({
            label: m.length > 20 ? m.substring(0, 20) + '…' : m,
            data: tipos.map(t => { const c = getCell(m, t); return c ? parseFloat(c.TasaVulnerabilidad) : null; }),
            backgroundColor: PALETTE[i % PALETTE.length] + '33',
            borderColor:     PALETTE[i % PALETTE.length],
            borderWidth: 1, borderRadius: 3,
        }));

        new Chart(ctxBarras, {
            type: 'bar',
            data: { labels: tipos.map(t => abrev[t] || t), datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, position: 'top', labels: { color: textCol, boxWidth: 10, padding: 10 } },
                    tooltip: { callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y?.toFixed(0)}%` } }
                },
                scales: {
                    x: { grid: { color: gridCol }, ticks: { color: textCol } },
                    y: { beginAtZero: true, max: 100, grid: { color: gridCol },
                         ticks: { color: textCol, callback: v => v + '%' } }
                }
            }
        });
    }

    /* ── 3. TIEMPO MEDIO DE RESPUESTA ──────────────────────── */
    const ctxTiempo = document.getElementById('chartTiempo');
    if (ctxTiempo) {
        // Tiempo medio por modelo (promedio sobre tipos que tienen dato)
        const datasets = modelos.map((m, i) => {
            const tiemposMs = tipos
                .map(t => getCell(m, t))
                .filter(c => c && c.TiempoMedio)
                .map(c => c.TiempoMedio / 1000); // convertir a segundos

            return {
                label: m.length > 20 ? m.substring(0, 20) + '…' : m,
                data: tipos.map(t => {
                    const c = getCell(m, t);
                    return c && c.TiempoMedio ? (c.TiempoMedio / 1000) : null;
                }),
                backgroundColor: PALETTE[i % PALETTE.length] + '33',
                borderColor:     PALETTE[i % PALETTE.length],
                borderWidth: 1, borderRadius: 3,
            };
        });

        new Chart(ctxTiempo, {
            type: 'bar',
            data: { labels: tipos.map(t => abrev[t] || t), datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, position: 'top', labels: { color: textCol, boxWidth: 10, padding: 10 } },
                    tooltip: { callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y?.toFixed(2)}s` } }
                },
                scales: {
                    x: { grid: { color: gridCol }, ticks: { color: textCol } },
                    y: { beginAtZero: true, grid: { color: gridCol },
                         ticks: { color: textCol, callback: v => v + 's' } }
                }
            }
        });
    }

    /* ── 4. SEVERIDADES APILADAS ───────────────────────────── */
    const ctxSev = document.getElementById('chartSeveridad');
    if (ctxSev) {
        const altaData  = modelos.map(m => tipos.reduce((acc, t) => { const c = getCell(m,t); return acc + (c?.SeveridadAlta  ?? 0); }, 0));
        const mediaData = modelos.map(m => tipos.reduce((acc, t) => { const c = getCell(m,t); return acc + (c?.SeveridadMedia ?? 0); }, 0));
        const bajaData  = modelos.map(m => tipos.reduce((acc, t) => { const c = getCell(m,t); return acc + (c?.SeveridadBaja  ?? 0); }, 0));

        const labels = modelos.map(m => m.length > 18 ? m.substring(0, 18) + '…' : m);

        new Chart(ctxSev, {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    { label: 'Alta',  data: altaData,  backgroundColor: '#dc354566', borderColor: '#dc3545', borderWidth: 1, borderRadius: 0 },
                    { label: 'Media', data: mediaData, backgroundColor: '#ffaa0055', borderColor: '#ffaa00', borderWidth: 1, borderRadius: 0 },
                    { label: 'Baja',  data: bajaData,  backgroundColor: '#4488ff44', borderColor: '#4488ff', borderWidth: 1, borderRadius: 0 },
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, position: 'top', labels: { color: textCol, boxWidth: 10, padding: 10 } },
                    tooltip: { callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y}` } }
                },
                scales: {
                    x: { stacked: true, grid: { color: gridCol }, ticks: { color: textCol } },
                    y: { stacked: true, beginAtZero: true, grid: { color: gridCol },
                         ticks: { color: textCol, stepSize: 1 } }
                }
            }
        });
    }
}());
</script>
}
