@* ============================================================
   Views/Auditoria/Detalle.cshtml — Detalle completo de un ataque
   AI Red Teaming Platform - TFG Ingeniería Informática
   FASE 2 — Muestra análisis completo del juez IA
   ============================================================ *@

@model TFG_Portal.Models.AtaqueDetalle
@{
    ViewData["Title"] = $"Ataque #{Model.Id}";
}

@* ── Cabecera ── *@
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
    <div class="d-flex align-items-center gap-3">
        <div class="page-header-icon">
            <i class="fa-solid fa-magnifying-glass"></i>
        </div>
        <div>
            <h1 class="page-title">Ataque #@Model.Id</h1>
            <p class="page-subtitle">
                <span class="badge-tipo-ataque me-2">@Model.TipoAtaque</span>
                @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm:ss")
            </p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Auditoria" asp-action="Historial"
           class="btn-redteam-secondary">
            <i class="fa-solid fa-arrow-left"></i> Volver
        </a>
        <a asp-controller="Auditoria" asp-action="Nueva"
           class="btn-redteam-primary">
            <i class="fa-solid fa-crosshairs"></i> Nuevo Ataque
        </a>
    </div>
</div>

@* ── Resultado badge grande ── *@
<div class="mb-4 d-flex align-items-center gap-3 flex-wrap">
    @if (Model.FueVulnerable)
    {
        <span class="badge-vulnerable badge-vulnerable-lg">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>VULNERABLE
        </span>
        @if (!string.IsNullOrEmpty(Model.Severidad))
        {
            <span class="@Model.SeveridadBadgeClass" style="font-size: 0.85rem; padding: 6px 14px;">
                Severidad: @Model.Severidad
            </span>
        }
    }
    else
    {
        <span class="badge-seguro badge-seguro-lg">
            <i class="fa-solid fa-shield-halved me-2"></i>SEGURO
        </span>
    }
</div>

<div class="row g-4">

    @* ── Columna izquierda ── *@
    <div class="col-lg-8">

        @* ── Panel del juez IA ── *@
        @if (!string.IsNullOrEmpty(Model.Justificacion) || !string.IsNullOrEmpty(Model.Recomendacion))
        {
            <div class="card-redteam mb-4">
                <div class="card-redteam-header">
                    <span class="card-redteam-title">
                        <i class="fa-solid fa-gavel me-2" style="color: var(--color-yellow);"></i>
                        VEREDICTO DEL JUEZ IA
                    </span>
                    <span style="font-family: var(--font-code); font-size: 0.65rem; color: var(--color-text-dim);">
                        WhiteRabbitNeo (evaluador fijo)
                    </span>
                </div>
                <div class="card-redteam-body">

                    @* Justificación *@
                    @if (!string.IsNullOrEmpty(Model.Justificacion))
                    {
                        <div class="mb-4">
                            <div class="label-redteam mb-2">
                                <i class="fa-solid fa-magnifying-glass-chart me-1"></i>
                                Justificación
                            </div>
                            <div class="juez-text-block">
                                @Model.Justificacion
                            </div>
                        </div>
                    }

                    @* Recomendación *@
                    @if (!string.IsNullOrEmpty(Model.Recomendacion))
                    {
                        <div class="mb-3">
                            <div class="label-redteam mb-2">
                                <i class="fa-solid fa-shield-halved me-1"></i>
                                Recomendación de Mitigación
                            </div>
                            <div class="juez-recomendacion-block">
                                <i class="fa-solid fa-lightbulb me-2"></i>
                                @Model.Recomendacion
                            </div>
                        </div>
                    }

                    @* Clasificación del juez *@
                    <div class="juez-clasificacion">
                        <div class="juez-clasificacion-item">
                            <span class="label-redteam">Tipo Payload</span>
                            <span class="badge-tipo-payload badge-payload-@(Model.TipoPayload ?? "desconocido")">
                                @(Model.TipoPayload ?? "—")
                            </span>
                        </div>
                        @if (Model.FueVulnerable && !string.IsNullOrEmpty(Model.Severidad))
                        {
                            <div class="juez-clasificacion-item">
                                <span class="label-redteam">Severidad</span>
                                <span class="@Model.SeveridadBadgeClass">@Model.Severidad</span>
                            </div>
                        }
                        <div class="juez-clasificacion-item">
                            <span class="label-redteam">Nivel Prompt</span>
                            <span class="badge-nivel-inline">
                                Nivel @(Model.NivelPrompt ?? 0) — @Model.NivelPromptEtiqueta
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Prompt enviado *@
        <div class="card-redteam mb-4">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-arrow-up-from-bracket me-2" style="color: var(--color-yellow);"></i>
                    PROMPT ENVIADO
                </span>
                @if (Model.NivelPrompt.HasValue)
                {
                    <span style="font-family: var(--font-code); font-size: 0.68rem; color: var(--color-text-dim);">
                        Nivel @Model.NivelPrompt — @Model.NivelPromptEtiqueta
                    </span>
                }
            </div>
            <div class="card-redteam-body">
                <div class="code-block-header">
                    <span>user prompt</span>
                </div>
                <div class="code-block">
                    <pre><code>@Model.PromptEnviado</code></pre>
                </div>
            </div>
        </div>

        @* Respuesta de la IA *@
        <div class="card-redteam">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-robot me-2" style="color: var(--color-green);"></i>
                    RESPUESTA DEL MODELO AUDITADO
                </span>
            </div>
            <div class="card-redteam-body">
                <div class="code-block-header">
                    <span>assistant response</span>
                    <span style="color: var(--color-green); font-size: 0.68rem;">
                        @Model.ModeloIa
                    </span>
                </div>
                <div class="code-block" style="max-height: 480px; overflow-y: auto;">
                    <pre><code>@Model.RespuestaIa</code></pre>
                </div>
            </div>
        </div>

    </div>

    @* ── Columna derecha — Metadata ── *@
    <div class="col-lg-4">

        @* Métricas rápidas *@
        <div class="card-redteam mb-4">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-chart-simple me-2"></i>
                    MÉTRICAS
                </span>
            </div>
            <div class="card-redteam-body" style="padding: 0;">
                <dl class="meta-list">
                    <div class="meta-item">
                        <dt>Tiempo de Respuesta</dt>
                        <dd class="mono" style="color: var(--color-yellow);">
                            @Model.TiempoRespuestaFormateado
                        </dd>
                    </div>
                    <div class="meta-item">
                        <dt>Iteraciones</dt>
                        <dd>
                            <span class="mono">@Model.Iteraciones / 3</span>
                            @if (Model.Iteraciones == 1)
                            {
                                <span class="ms-1" style="font-size: 0.7rem; color: var(--color-green);">
                                    (primer intento)
                                </span>
                            }
                            else if (Model.Iteraciones >= 3)
                            {
                                <span class="ms-1" style="font-size: 0.7rem; color: var(--color-red);">
                                    (agotados)
                                </span>
                            }
                        </dd>
                    </div>
                    <div class="meta-item">
                        <dt>Nivel de Prompt</dt>
                        <dd>
                            @if (Model.NivelPrompt.HasValue)
                            {
                                <span class="badge-nivel-inline">
                                    @Model.NivelPrompt — @Model.NivelPromptEtiqueta
                                </span>
                            }
                            else
                            {
                                <span style="color: var(--color-text-dim);">—</span>
                            }
                        </dd>
                    </div>
                    <div class="meta-item">
                        <dt>Tipo Payload</dt>
                        <dd>
                            <span class="badge-tipo-payload badge-payload-@(Model.TipoPayload ?? "desconocido")">
                                @(Model.TipoPayload ?? "—")
                            </span>
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

        @* Metadatos del ataque *@
        <div class="card-redteam mb-4">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-circle-info me-2"></i>
                    METADATOS
                </span>
            </div>
            <div class="card-redteam-body" style="padding: 0;">
                <dl class="meta-list">
                    <div class="meta-item">
                        <dt>ID Ataque</dt>
                        <dd class="mono">#@Model.Id</dd>
                    </div>
                    <div class="meta-item">
                        <dt>Tipo</dt>
                        <dd><span class="badge-tipo-ataque">@Model.TipoAtaque</span></dd>
                    </div>
                    <div class="meta-item">
                        <dt>Resultado</dt>
                        <dd>
                            @if (Model.FueVulnerable)
                            {
                                <span class="badge-vulnerable">Vulnerable</span>
                            }
                            else
                            {
                                <span class="badge-seguro">Seguro</span>
                            }
                        </dd>
                    </div>
                    <div class="meta-item">
                        <dt>Fecha</dt>
                        <dd class="mono" style="font-size: 0.75rem;">
                            @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm:ss")
                        </dd>
                    </div>
                    <div class="meta-item">
                        <dt>ID Auditoría</dt>
                        <dd class="mono">#@Model.AuditoriaId</dd>
                    </div>
                </dl>
            </div>
        </div>

        @* Auditoría padre *@
        <div class="card-redteam">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-folder-open me-2"></i>
                    AUDITORÍA PADRE
                </span>
            </div>
            <div class="card-redteam-body" style="padding: 0;">
                <dl class="meta-list">
                    <div class="meta-item">
                        <dt>Modelo Auditado</dt>
                        <dd class="mono" style="font-size: 0.7rem; word-break: break-all;">
                            @Model.ModeloIa
                        </dd>
                    </div>
                    <div class="meta-item">
                        <dt>Descripción</dt>
                        <dd style="color: var(--color-text-muted); font-size: 0.8rem;">
                            @(string.IsNullOrEmpty(Model.AuditoriaDescripcion) ? "—" : Model.AuditoriaDescripcion)
                        </dd>
                    </div>
                    <div class="meta-item">
                        <dt>Fecha inicio</dt>
                        <dd class="mono" style="font-size: 0.75rem;">
                            @Model.AuditoriaFechaCreacion.ToString("dd/MM/yyyy HH:mm")
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

    </div>
</div>

@section Styles {
<style>
    /* ── Meta list (sin cambios) ── */
    .meta-list { margin: 0; padding: 0; }
    .meta-item {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 16px; border-bottom: 1px solid var(--color-border); gap: 12px;
    }
    .meta-item:last-child { border-bottom: none; }
    .meta-item dt {
        font-family: var(--font-ui); font-size: 0.72rem; font-weight: 600;
        color: var(--color-text-dim); text-transform: uppercase;
        letter-spacing: 0.08em; white-space: nowrap; flex-shrink: 0;
    }
    .meta-item dd { margin: 0; text-align: right; font-size: 0.82rem; color: var(--color-text); }

    /* ── Panel del juez ── */
    .juez-text-block {
        background: rgba(255, 170, 0, 0.06);
        border: 1px solid rgba(255, 170, 0, 0.15);
        border-left: 3px solid var(--color-yellow);
        border-radius: var(--radius);
        padding: 14px 18px;
        font-family: var(--font-ui); font-size: 0.85rem;
        color: var(--color-text); line-height: 1.7;
    }
    .juez-recomendacion-block {
        background: rgba(0, 255, 65, 0.04);
        border: 1px solid rgba(0, 255, 65, 0.12);
        border-left: 3px solid var(--color-green);
        border-radius: var(--radius);
        padding: 14px 18px;
        font-family: var(--font-ui); font-size: 0.85rem;
        color: var(--color-text-muted); line-height: 1.7;
    }
    .juez-clasificacion {
        display: flex; gap: 20px; flex-wrap: wrap;
        padding-top: 16px; border-top: 1px solid var(--color-border); margin-top: 8px;
    }
    .juez-clasificacion-item {
        display: flex; flex-direction: column; gap: 6px;
    }

    /* ── Badges de tipo payload ── */
    .badge-tipo-payload {
        font-family: var(--font-code); font-size: 0.72rem; font-weight: 500;
        padding: 3px 10px; border-radius: 3px; letter-spacing: 0.04em;
        display: inline-block; text-transform: uppercase;
    }
    .badge-payload-funcional {
        background: rgba(68, 136, 255, 0.12); border: 1px solid rgba(68, 136, 255, 0.4);
        color: #4488ff;
    }
    .badge-payload-generico {
        background: rgba(136, 136, 136, 0.12); border: 1px solid rgba(136, 136, 136, 0.3);
        color: #888888;
    }
    .badge-payload-rechazo {
        background: rgba(0, 255, 65, 0.08); border: 1px solid rgba(0, 255, 65, 0.25);
        color: var(--color-green);
    }
    .badge-payload-desconocido {
        background: var(--color-bg-tertiary); border: 1px solid var(--color-border);
        color: var(--color-text-dim);
    }

    /* ── Badge nivel prompt inline ── */
    .badge-nivel-inline {
        font-family: var(--font-code); font-size: 0.72rem;
        color: var(--color-text-muted); padding: 2px 8px;
        background: var(--color-bg-tertiary); border: 1px solid var(--color-border);
        border-radius: 3px; display: inline-block;
    }
</style>
}