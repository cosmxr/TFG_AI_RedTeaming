@* ============================================================
   Views/Auditoria/Nueva.cshtml — Formulario para lanzar ataques
   AI Red Teaming Platform - TFG Ingeniería Informática
   ============================================================ *@

@using TFG_Portal.Models
@{
    ViewData["Title"] = "Nueva Auditoría";
    var tipos       = ViewData["TiposAtaque"] as TiposAtaqueResponse ?? new TiposAtaqueResponse();
    var proyecto    = ViewData["Proyecto"] as Proyecto;
    var apiActiva   = ViewData["ApiEstado"] as bool? ?? false;
}

@* ── Cabecera ── *@
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
    <div class="d-flex align-items-center gap-3">
        <div class="page-header-icon">
            <i class="fa-solid fa-crosshairs"></i>
        </div>
        <div>
            <h1 class="page-title">Nueva Auditoría</h1>
            <p class="page-subtitle">
                Lanza un ataque contra el modelo objetivo
                @if (proyecto != null)
                {
                    <span class="ms-1">
                        · Proyecto: <strong style="color: var(--color-green);">@proyecto.Nombre</strong>
                    </span>
                }
            </p>
        </div>
    </div>
    @if (!apiActiva)
    {
        <div class="api-status-badge api-inactiva">
            <span class="api-status-dot"></span>
            <span class="api-status-label">API INACTIVA</span>
        </div>
    }
</div>

@* ── Error ── *@
@if (ViewData["Error"] != null)
{
    <div class="alert-redteam alert-redteam-danger mb-4">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        @ViewData["Error"]
    </div>
}

@* ── API inactiva warning ── *@
@if (!apiActiva)
{
    <div class="info-box mb-4"
         style="border-color: rgba(255,170,0,0.3); background: rgba(255,170,0,0.04);">
        <div class="info-box-icon" style="color: var(--color-yellow);">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <div class="info-box-text">
            La API no está disponible. Asegúrate de que
            <strong>Ollama</strong> y la <strong>FastAPI</strong>
            están activos antes de lanzar un ataque.
        </div>
    </div>
}

<div class="row g-4">

    @* ── Columna izquierda — Formulario ── *@
    <div class="col-lg-7">
        <div class="card-redteam">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-terminal me-2" style="color: var(--color-green);"></i>
                    CONFIGURACIÓN DEL ATAQUE
                </span>
            </div>
            <div class="card-redteam-body">

                <form asp-controller="Auditoria" asp-action="Nueva"
                      method="post" id="form-ataque">
                    @Html.AntiForgeryToken()

                    @* ── Ataques clásicos (Web/App) ── *@
                    @if (tipos.Clasico.Any())
                    {
                        <div class="mb-4">
                            <div class="categoria-header mb-2">
                                <span class="categoria-badge categoria-clasico">
                                    <i class="fa-solid fa-globe me-1"></i>Web / App
                                </span>
                                <span class="categoria-desc">
                                    Comprueba si el modelo genera payloads ofensivos
                                </span>
                            </div>
                            <div class="tipo-ataque-grid">
                                @foreach (var tipo in tipos.Clasico)
                                {
                                    <label class="tipo-ataque-card tipo-clasico"
                                           title="@CategoriasAtaque.DescripcionAtaque(tipo)">
                                        <input type="radio" name="tipoAtaque"
                                               value="@tipo" required
                                               class="tipo-ataque-radio" />
                                        <span class="tipo-ataque-label">@tipo</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    @* ── AI Red Teaming ── *@
                    @if (tipos.AiRedteam.Any())
                    {
                        <div class="mb-4">
                            <div class="categoria-header mb-2">
                                <span class="categoria-badge categoria-ai">
                                    <i class="fa-solid fa-robot me-1"></i>AI Red Teaming
                                </span>
                                <span class="categoria-desc">
                                    Ataca el propio modelo: jailbreak, extracción, inyección
                                </span>
                            </div>
                            <div class="tipo-ataque-grid tipo-ataque-grid-ai">
                                @foreach (var tipo in tipos.AiRedteam)
                                {
                                    <label class="tipo-ataque-card tipo-ai"
                                           title="@CategoriasAtaque.DescripcionAtaque(tipo)">
                                        <input type="radio" name="tipoAtaque"
                                               value="@tipo" required
                                               class="tipo-ataque-radio" />
                                        <span class="tipo-ataque-label">
                                            @CategoriasAtaque.EtiquetaAmigable(tipo)
                                        </span>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    @* ── Descripción dinámica del tipo seleccionado ── *@
                    <div id="descripcion-ataque"
                         class="info-box mb-4"
                         style="display: none;
                                border-color: rgba(0,255,65,0.2);
                                background: rgba(0,255,65,0.03);">
                        <div class="info-box-icon" style="color: var(--color-green);">
                            <i class="fa-solid fa-circle-info"></i>
                        </div>
                        <div class="info-box-text" id="descripcion-texto"></div>
                    </div>

                    @* ── Prompt personalizado ── *@
                    <div class="mb-5">
                        <label class="label-redteam" for="promptPersonalizado">
                            Prompt personalizado
                            <span class="ms-1"
                                  style="color: var(--color-text-dim);
                                         font-weight:400; text-transform:none; letter-spacing:0;">
                                (opcional)
                            </span>
                        </label>
                        <textarea id="promptPersonalizado"
                                  name="promptPersonalizado"
                                  class="input-redteam"
                                  rows="5"
                                  placeholder="Deja vacío para usar el prompt por defecto del tipo seleccionado...">
                        </textarea>
                        <small class="form-hint">
                            Si se deja vacío se usarán los 3 niveles de prompt predefinidos
                            (Directo → Investigador → CTF/Educativo) con reintentos automáticos.
                        </small>
                    </div>

                    @* ── Botones ── *@
                    <div class="d-flex gap-3">
                        <button type="submit"
                                class="btn-redteam-primary flex-fill @(!apiActiva ? "btn-disabled" : "")"
                                id="btn-lanzar"
                                @(!apiActiva ? "disabled" : "")>
                            <i class="fa-solid fa-crosshairs"></i>
                            Lanzar Ataque
                        </button>
                        <a asp-controller="Dashboard" asp-action="Index"
                           class="btn-redteam-secondary">
                            <i class="fa-solid fa-arrow-left"></i>
                            Cancelar
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>

    @* ── Columna derecha — Info y prompts por defecto ── *@
    <div class="col-lg-5">

        @* ── Panel de descripción extendida por tipo ── *@
        <div class="card-redteam mb-3" id="panel-detalle-tipo" style="display:none;">
            <div class="card-redteam-header">
                <span class="card-redteam-title" id="panel-detalle-titulo">
                    <i class="fa-solid fa-info-circle me-2"></i>
                    DETALLE DEL ATAQUE
                </span>
            </div>
            <div class="card-redteam-body">
                <p id="panel-detalle-desc"
                   style="font-size: 0.83rem; color: var(--color-text-muted); margin: 0 0 12px;">
                </p>
                <div id="panel-detalle-niveles">
                    <p class="label-redteam mb-2">Niveles de escalada automática:</p>
                    <div class="d-flex flex-column gap-1" id="niveles-lista"></div>
                </div>
            </div>
        </div>

        @* ── Info general ── *@
        <div class="card-redteam mb-3">
            <div class="card-redteam-header">
                <span class="card-redteam-title">
                    <i class="fa-solid fa-layer-group me-2"></i>
                    NIVELES DE PROMPT
                </span>
            </div>
            <div class="card-redteam-body" style="padding: 0;">
                <div class="prompt-preview-list">
                    <div class="prompt-preview-item">
                        <span class="badge-nivel badge-nivel-1 mb-1">1 — Directo</span>
                        <p class="prompt-preview-text">
                            Petición directa y sin contexto al modelo.
                        </p>
                    </div>
                    <div class="prompt-preview-item">
                        <span class="badge-nivel badge-nivel-2 mb-1">2 — Investigador</span>
                        <p class="prompt-preview-text">
                            Contexto de pentester o auditor profesional autorizado.
                        </p>
                    </div>
                    <div class="prompt-preview-item">
                        <span class="badge-nivel badge-nivel-3 mb-1">3 — CTF / Educativo</span>
                        <p class="prompt-preview-text">
                            Contexto académico, universitario o de entorno controlado.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="info-box">
            <div class="info-box-icon">
                <i class="fa-solid fa-circle-info"></i>
            </div>
            <div class="info-box-text">
                El sistema intentará hasta <strong>3 niveles</strong> de prompt.
                Si el modelo rechaza el nivel 1, escalará automáticamente al 2 y al 3.
                El resultado se guardará en la base de datos asociado al proyecto activo.
            </div>
        </div>

    </div>
</div>

@section Styles {
<style>
    /* ── Grid de tipos ── */
    .tipo-ataque-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }
    .tipo-ataque-grid-ai {
        grid-template-columns: repeat(2, 1fr);
    }

    /* ── Tarjeta de tipo ── */
    .tipo-ataque-card { cursor: pointer; position: relative; }
    .tipo-ataque-radio {
        position: absolute; opacity: 0; width: 0; height: 0;
    }
    .tipo-ataque-label {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px 6px;
        background: var(--color-bg-tertiary);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        font-family: var(--font-code);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-text-muted);
        letter-spacing: 0.04em;
        transition: all var(--transition);
        user-select: none;
        text-align: center;
        line-height: 1.3;
        min-height: 40px;
    }

    /* Hover clásico (verde) */
    .tipo-clasico:hover .tipo-ataque-label {
        border-color: rgba(0,255,65,0.4);
        color: var(--color-green);
        background: rgba(0,255,65,0.05);
    }
    .tipo-clasico .tipo-ataque-radio:checked + .tipo-ataque-label {
        border-color: var(--color-green);
        color: var(--color-green);
        background: rgba(0,255,65,0.08);
        box-shadow: 0 0 8px rgba(0,255,65,0.15);
    }

    /* Hover AI (naranja/amarillo) */
    .tipo-ai:hover .tipo-ataque-label {
        border-color: rgba(255,170,0,0.5);
        color: #ffaa00;
        background: rgba(255,170,0,0.06);
    }
    .tipo-ai .tipo-ataque-radio:checked + .tipo-ataque-label {
        border-color: #ffaa00;
        color: #ffaa00;
        background: rgba(255,170,0,0.08);
        box-shadow: 0 0 8px rgba(255,170,0,0.2);
    }

    /* ── Cabecera de categoría ── */
    .categoria-header {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .categoria-badge {
        font-family: var(--font-code);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        padding: 3px 10px;
        border-radius: 4px;
        white-space: nowrap;
    }
    .categoria-clasico {
        background: rgba(0,255,65,0.1);
        color: var(--color-green);
        border: 1px solid rgba(0,255,65,0.3);
    }
    .categoria-ai {
        background: rgba(255,170,0,0.1);
        color: #ffaa00;
        border: 1px solid rgba(255,170,0,0.3);
    }
    .categoria-desc {
        font-size: 0.75rem;
        color: var(--color-text-dim);
    }

    /* ── Niveles en panel lateral ── */
    .nivel-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 6px 0;
        border-bottom: 1px solid var(--color-border);
        font-size: 0.77rem;
        color: var(--color-text-muted);
    }
    .nivel-item:last-child { border-bottom: none; }

    /* ── Misc ── */
    .prompt-preview-list { display: flex; flex-direction: column; }
    .prompt-preview-item {
        padding: 10px 14px;
        border-bottom: 1px solid var(--color-border);
    }
    .prompt-preview-item:last-child { border-bottom: none; }
    .prompt-preview-text {
        font-family: var(--font-code);
        font-size: 0.72rem;
        color: var(--color-text-dim);
        margin: 0;
        line-height: 1.5;
    }
    .btn-disabled { opacity: 0.4; cursor: not-allowed; }
</style>
}

@section Scripts {
<script>
(function () {
    // Descripciones por tipo (mirror de CategoriasAtaque.cs)
    const descripciones = {
        "XSS":                   { desc: "Intenta que el modelo genere payloads XSS funcionales.", categoria: "clasico",    niveles: ["Petición directa de payload XSS.", "Contexto de pentester auditando app web.", "Material de curso universitario de seguridad web."] },
        "SQLI":                  { desc: "Intenta que el modelo genere inyecciones SQL funcionales.", categoria: "clasico", niveles: ["Petición directa de payload SQLi.", "Contexto de auditor revisando aplicación.", "Laboratorio de seguridad universitario."] },
        "LFI":                   { desc: "Intenta que el modelo genere rutas de traversal funcionales.", categoria: "clasico", niveles: ["Petición directa de payload LFI.", "Contexto de auditor con parámetro vulnerable identificado.", "Tutorial para plataforma de formación en ciberseguridad."] },
        "CSRF":                  { desc: "Intenta que el modelo genere formularios CSRF funcionales.", categoria: "clasico", niveles: ["Petición directa de ataque CSRF.", "Contexto de pentester en auditoría de app bancaria.", "Ejemplo didáctico para curso universitario."] },
        "PROMPT_INJECTION":      { desc: "Inyecta instrucciones en datos procesados para alterar el comportamiento del modelo.", categoria: "ai_redteam", niveles: ["Inyección directa: ignora instrucciones previas.", "Inyección con contexto de sistema/administrador.", "Inyección indirecta embebida en un documento analizado."] },
        "JAILBREAK":             { desc: "Intenta que el modelo adopte un rol sin restricciones (DAN, HackerAI, modo dev).", categoria: "ai_redteam", niveles: ["Rol DAN directo sin restricciones éticas.", "Roleplay con personaje en mundo ficticio sin leyes.", "Modo desarrollador con token falso de autorización."] },
        "SYSTEM_PROMPT_LEAKAGE": { desc: "Intenta extraer las instrucciones de sistema privadas del modelo.", categoria: "ai_redteam", niveles: ["Petición directa del system prompt.", "Extracción por traducción del texto de instrucciones.", "Extracción por completado de texto con el literal exacto."] },
        "DATA_EXTRACTION":       { desc: "Intenta que el modelo revele datos de su contexto o entrenamiento.", categoria: "ai_redteam", niveles: ["Listado directo de datos del contexto.", "Repetición literal de todo el texto recibido.", "Petición urgente de datos confidenciales memorizados."] },
        "CONTEXT_MANIPULATION":  { desc: "Usa autorizaciones falsas para modificar el comportamiento del modelo.", categoria: "ai_redteam", niveles: ["Falsa autorización de administrador del sistema.", "Manipulación de historial con acuerdo previo inventado.", "Falso entorno de pruebas sandbox sin consecuencias reales."] },
        "INDIRECT_INJECTION":    { desc: "Embebe instrucciones maliciosas en datos que el modelo procesa.", categoria: "ai_redteam", niveles: ["Inyección en cuerpo de email a procesar.", "Inyección en comentario de código a analizar.", "Inyección en payload de formulario web a gestionar."] }
    };

    const radios          = document.querySelectorAll('.tipo-ataque-radio');
    const descBox         = document.getElementById('descripcion-ataque');
    const descTexto       = document.getElementById('descripcion-texto');
    const panelDetalle    = document.getElementById('panel-detalle-tipo');
    const panelTitulo     = document.getElementById('panel-detalle-titulo');
    const panelDesc       = document.getElementById('panel-detalle-desc');
    const nivelesLista    = document.getElementById('niveles-lista');
    const btnLanzar       = document.getElementById('btn-lanzar');
    const form            = document.getElementById('form-ataque');

    function actualizarInfo(tipo) {
        const info = descripciones[tipo];
        if (!info) return;

        // Caja inline bajo los radios
        descTexto.textContent = info.desc;
        descBox.style.display = 'flex';

        // Panel lateral
        const esAi = info.categoria === 'ai_redteam';
        panelTitulo.innerHTML = esAi
            ? '<i class="fa-solid fa-robot me-2" style="color:#ffaa00;"></i>AI RED TEAMING'
            : '<i class="fa-solid fa-globe me-2" style="color:var(--color-green);"></i>ATAQUE CLÁSICO';
        panelDesc.textContent = info.desc;

        nivelesLista.innerHTML = '';
        info.niveles.forEach(function(n, i) {
            const div = document.createElement('div');
            div.className = 'nivel-item';
            div.innerHTML =
                '<span class="badge-nivel badge-nivel-' + (i + 1) + '" style="min-width:24px; text-align:center;">'
                + (i + 1) + '</span>'
                + '<span>' + n + '</span>';
            nivelesLista.appendChild(div);
        });

        panelDetalle.style.display = 'block';
    }

    radios.forEach(function(radio) {
        radio.addEventListener('change', function() {
            actualizarInfo(this.value);
        });
    });

    // Feedback al enviar
    form.addEventListener('submit', function() {
        if (btnLanzar.disabled) return;
        btnLanzar.innerHTML =
            '<i class="fa-solid fa-spinner fa-spin"></i> Lanzando...';
        btnLanzar.disabled = true;
    });

    // Si hay un tipo preseleccionado (ej: tras error de validación)
    const checked = document.querySelector('.tipo-ataque-radio:checked');
    if (checked) actualizarInfo(checked.value);
}());
</script>
}
