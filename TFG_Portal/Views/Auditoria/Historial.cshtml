@* ============================================================
   Views/Auditoria/Historial.cshtml — Tabla completa de ataques
   AI Red Teaming Platform - TFG Ingeniería Informática
   ============================================================ *@

@model IEnumerable<TFG_Portal.Models.AtaqueListItem>
@{
    ViewData["Title"] = "Historial";
    var proyecto = ViewData["Proyecto"] as TFG_Portal.Models.Proyecto;
    var lista = Model.ToList();
}

@* ── Cabecera ── *@
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
    <div class="d-flex align-items-center gap-3">
        <div class="page-header-icon">
            <i class="fa-solid fa-list-ul"></i>
        </div>
        <div>
            <h1 class="page-title">Historial de Ataques</h1>
            <p class="page-subtitle">
                @lista.Count ataques registrados
                @if (proyecto != null)
                {
                    <span class="ms-1">· <strong style="color: var(--color-green);">@proyecto.Nombre</strong></span>
                }
            </p>
        </div>
    </div>
    <a asp-controller="Auditoria" asp-action="Nueva"
       class="btn-redteam-primary">
        <i class="fa-solid fa-crosshairs"></i>
        Nuevo Ataque
    </a>
</div>

@if (!lista.Any())
{
    <div class="card-redteam">
        <div class="empty-state-redteam" style="min-height: 260px;">
            <i class="fa-solid fa-folder-open fa-3x mb-4" style="opacity:0.2;"></i>
            <p style="font-size: 0.95rem; color: var(--color-text-muted);">No hay ataques registrados en este proyecto.</p>
            <a asp-controller="Auditoria" asp-action="Nueva" class="btn-redteam-primary mt-3">
                <i class="fa-solid fa-crosshairs me-1"></i> Lanzar primer ataque
            </a>
        </div>
    </div>
}
else
{
    @* ── Filtros ── *@
    <div class="d-flex gap-2 mb-3 flex-wrap">
        <input type="text"
               id="filtro-texto"
               class="input-redteam"
               placeholder="Buscar por tipo, prompt o modelo..."
               style="max-width: 320px;" />

        <select id="filtro-tipo" class="input-redteam" style="max-width: 160px;">
            <option value="">Todos los tipos</option>
            @foreach (var tipo in lista.Select(a => a.TipoAtaque).Distinct().OrderBy(t => t))
            {
                <option value="@tipo">@tipo</option>
            }
        </select>

        <select id="filtro-vulnerable" class="input-redteam" style="max-width: 180px;">
            <option value="">Todos los resultados</option>
            <option value="1">Solo vulnerables</option>
            <option value="0">Solo seguros</option>
        </select>

        <span id="contador-resultados"
              class="label-redteam d-flex align-items-center ms-auto"
              style="font-size: 0.72rem;">
            @lista.Count resultados
        </span>
    </div>

    @* ── Tabla ── *@
    <div class="card-redteam">
        <div class="table-responsive-redteam">
            <table class="table-redteam" id="tabla-historial">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tipo</th>
                        <th>Prompt</th>
                        <th>Modelo IA</th>
                        <th>Resultado</th>
                        <th>Fecha</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ataque in lista)
                    {
                        <tr class="fila-ataque"
                            data-tipo="@ataque.TipoAtaque"
                            data-vulnerable="@(ataque.FueVulnerable ? "1" : "0")"
                            data-texto="@ataque.TipoAtaque.ToLower() @ataque.PromptFragmento.ToLower() @ataque.ModeloIa.ToLower()">
                            <td class="col-meta">#@ataque.Id</td>
                            <td><span class="badge-tipo-ataque">@ataque.TipoAtaque</span></td>
                            <td style="max-width: 320px;">
                                <span class="mono"
                                      style="font-size: 0.75rem; color: var(--color-text-muted); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @ataque.PromptFragmento
                                </span>
                            </td>
                            <td>
                                <span class="mono" style="font-size: 0.72rem; color: var(--color-text-dim);">
                                    @(ataque.ModeloIa.Length > 24
                                        ? ataque.ModeloIa.Substring(0, 24) + "…"
                                        : ataque.ModeloIa)
                                </span>
                            </td>
                            <td>
                                @if (ataque.FueVulnerable)
                                {
                                    <span class="badge-vulnerable">Vulnerable</span>
                                }
                                else
                                {
                                    <span class="badge-seguro">Seguro</span>
                                }
                            </td>
                            <td class="col-meta">@ataque.FechaCreacion.ToString("dd/MM/yy HH:mm")</td>
                            <td>
                                <a asp-controller="Auditoria" asp-action="Detalle"
                                   asp-route-id="@ataque.Id"
                                   class="btn-redteam-secondary"
                                   style="padding: 4px 10px; font-size: 0.75rem;">
                                    Ver <i class="fa-solid fa-arrow-right ms-1"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    (function () {
        const filas = document.querySelectorAll('.fila-ataque');
        const filtroTexto = document.getElementById('filtro-texto');
        const filtroTipo = document.getElementById('filtro-tipo');
        const filtroVulnerable = document.getElementById('filtro-vulnerable');
        const contador = document.getElementById('contador-resultados');

        function filtrar() {
            const texto = filtroTexto.value.toLowerCase();
            const tipo = filtroTipo.value;
            const vulnerable = filtroVulnerable.value;
            let visibles = 0;

            filas.forEach(fila => {
                const matchTexto = !texto || fila.dataset.texto.includes(texto);
                const matchTipo = !tipo || fila.dataset.tipo === tipo;
                const matchVulnerable = !vulnerable || fila.dataset.vulnerable === vulnerable;

                if (matchTexto && matchTipo && matchVulnerable) {
                    fila.style.display = '';
                    visibles++;
                } else {
                    fila.style.display = 'none';
                }
            });

            if (contador) contador.textContent = visibles + ' resultados';
        }

        if (filtroTexto) filtroTexto.addEventListener('input', filtrar);
        if (filtroTipo) filtroTipo.addEventListener('change', filtrar);
        if (filtroVulnerable) filtroVulnerable.addEventListener('change', filtrar);
    })();
</script>
}