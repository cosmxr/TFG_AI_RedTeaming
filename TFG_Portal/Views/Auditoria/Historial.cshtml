@* ============================================================
   Views/Auditoria/Historial.cshtml — Tabla completa de ataques
   AI Red Teaming Platform - TFG Ingeniería Informática
   FASE 2 — Badges de severidad, tipo payload y nivel prompt
   ============================================================ *@

@model IEnumerable<TFG_Portal.Models.AtaqueListItem>
@{
    ViewData["Title"] = "Historial";
    var proyecto = ViewData["Proyecto"] as TFG_Portal.Models.Proyecto;
    var lista = Model.ToList();
}

@* ── Cabecera ── *@
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
    <div class="d-flex align-items-center gap-3">
        <div class="page-header-icon">
            <i class="fa-solid fa-list-ul"></i>
        </div>
        <div>
            <h1 class="page-title">Historial de Ataques</h1>
            <p class="page-subtitle">
                @lista.Count ataques registrados
                @if (proyecto != null)
                {
                    <span class="ms-1">· <strong style="color: var(--color-green);">@proyecto.Nombre</strong></span>
                }
            </p>
        </div>
    </div>
    <a asp-controller="Auditoria" asp-action="Nueva"
       class="btn-redteam-primary">
        <i class="fa-solid fa-crosshairs"></i> Nuevo Ataque
    </a>
</div>

@if (!lista.Any())
{
    <div class="card-redteam">
        <div class="empty-state-redteam" style="min-height: 260px;">
            <i class="fa-solid fa-folder-open fa-3x mb-4" style="opacity:0.2;"></i>
            <p style="font-size: 0.95rem; color: var(--color-text-muted);">No hay ataques registrados.</p>
            <a asp-controller="Auditoria" asp-action="Nueva" class="btn-redteam-primary mt-3">
                <i class="fa-solid fa-crosshairs me-1"></i> Lanzar primer ataque
            </a>
        </div>
    </div>
}
else
{
    @* ── Filtros ── *@
    <div class="d-flex gap-2 mb-3 flex-wrap">
        <input type="text" id="filtro-texto" class="input-redteam"
               placeholder="Buscar..." style="max-width: 260px;" />

        <select id="filtro-tipo" class="input-redteam" style="max-width: 140px;">
            <option value="">Todos los tipos</option>
            @foreach (var tipo in lista.Select(a => a.TipoAtaque).Distinct().OrderBy(t => t))
            {
                <option value="@tipo">@tipo</option>
            }
        </select>

        <select id="filtro-vulnerable" class="input-redteam" style="max-width: 160px;">
            <option value="">Todos</option>
            <option value="1">Vulnerables</option>
            <option value="0">Seguros</option>
        </select>

        <select id="filtro-severidad" class="input-redteam" style="max-width: 150px;">
            <option value="">Severidad</option>
            <option value="Alta">Alta</option>
            <option value="Media">Media</option>
            <option value="Baja">Baja</option>
        </select>

        <select id="filtro-payload" class="input-redteam" style="max-width: 160px;">
            <option value="">Tipo payload</option>
            <option value="funcional">Funcional</option>
            <option value="generico">Genérico</option>
            <option value="rechazo">Rechazo</option>
        </select>

        <span id="contador-resultados"
              class="label-redteam d-flex align-items-center ms-auto"
              style="font-size: 0.72rem;">
            @lista.Count resultados
        </span>
    </div>

    @* ── Tabla ── *@
    <div class="card-redteam">
        <div class="table-responsive-redteam">
            <table class="table-redteam" id="tabla-historial">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tipo</th>
                        <th>Prompt</th>
                        <th>Resultado</th>
                        <th>Severidad</th>
                        <th>Payload</th>
                        <th>Nivel</th>
                        <th>Fecha</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ataque in lista)
                    {
                        <tr class="fila-ataque"
                            data-tipo="@ataque.TipoAtaque"
                            data-vulnerable="@(ataque.FueVulnerable ? "1" : "0")"
                            data-severidad="@(ataque.Severidad ?? "")"
                            data-payload="@(ataque.TipoPayload ?? "")"
                            data-texto="@ataque.TipoAtaque.ToLower() @ataque.PromptFragmento.ToLower() @ataque.ModeloIa.ToLower()">

                            <td class="col-meta">#@ataque.Id</td>

                            <td>
                                <span class="badge-tipo-ataque">@ataque.TipoAtaque</span>
                                <span class="@ataque.CategoriaBadgeClass ms-1"
                                      style="font-size:0.63rem;">@ataque.CategoriaEtiqueta</span>
                            </td>

                            <td style="max-width: 240px;">
                                <span class="mono" style="font-size: 0.73rem; color: var(--color-text-muted);
                                       display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @ataque.PromptFragmento
                                </span>
                            </td>

                            <td>
                                @if (ataque.FueVulnerable)
                                {
                                    <span class="badge-vulnerable">Vulnerable</span>
                                }
                                else
                                {
                                    <span class="badge-seguro">Seguro</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(ataque.Severidad))
                                {
                                    <span class="@ataque.SeveridadBadgeClass">@ataque.Severidad</span>
                                }
                                else
                                {
                                    <span style="color: var(--color-text-dim);">—</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(ataque.TipoPayload))
                                {
                                    <span class="@ataque.TipoPayloadBadgeClass">@ataque.TipoPayload</span>
                                }
                                else
                                {
                                    <span style="color: var(--color-text-dim);">—</span>
                                }
                            </td>

                            <td class="col-meta text-center">
                                @if (ataque.NivelPrompt.HasValue)
                                {
                                    <span title="@ataque.NivelPromptEtiqueta">@ataque.NivelPrompt</span>
                                }
                                else
                                {
                                    <span style="color: var(--color-text-dim);">—</span>
                                }
                            </td>

                            <td class="col-meta">@ataque.FechaCreacion.ToString("dd/MM/yy HH:mm")</td>

                            <td>
                                <a asp-controller="Auditoria" asp-action="Detalle"
                                   asp-route-id="@ataque.Id"
                                   class="btn-redteam-secondary"
                                   style="padding: 4px 10px; font-size: 0.75rem;">
                                    Ver <i class="fa-solid fa-arrow-right ms-1"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    (function () {
        const filas = document.querySelectorAll('.fila-ataque');
        const filtros = {
            texto: document.getElementById('filtro-texto'),
            tipo: document.getElementById('filtro-tipo'),
            vulnerable: document.getElementById('filtro-vulnerable'),
            severidad: document.getElementById('filtro-severidad'),
            payload: document.getElementById('filtro-payload')
        };
        const contador = document.getElementById('contador-resultados');

        function filtrar() {
            const texto = (filtros.texto?.value || '').toLowerCase();
            const tipo = filtros.tipo?.value || '';
            const vuln = filtros.vulnerable?.value || '';
            const sev = filtros.severidad?.value || '';
            const pay = filtros.payload?.value || '';
            let visibles = 0;

            filas.forEach(fila => {
                const ok =
                    (!texto || fila.dataset.texto.includes(texto)) &&
                    (!tipo || fila.dataset.tipo === tipo) &&
                    (!vuln || fila.dataset.vulnerable === vuln) &&
                    (!sev || fila.dataset.severidad === sev) &&
                    (!pay || fila.dataset.payload === pay);

                fila.style.display = ok ? '' : 'none';
                if (ok) visibles++;
            });

            if (contador) contador.textContent = visibles + ' resultados';
        }

        Object.values(filtros).forEach(el => {
            if (el) el.addEventListener(el.tagName === 'INPUT' ? 'input' : 'change', filtrar);
        });
    })();
</script>
}