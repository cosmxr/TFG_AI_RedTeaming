@* ============================================================
   Views/Auditoria/Historial.cshtml — Tabla completa de ataques
   AI Red Teaming Platform - TFG Ingeniería Informática
   v6.0 — benchmark plano, canary_detectado, sin nivel_prompt
   ============================================================ *@

@model IEnumerable<TFG_Portal.Models.AtaqueListItem>
@{
    ViewData["Title"] = "Historial";
    var proyecto = ViewData["Proyecto"] as TFG_Portal.Models.Proyecto;
    var lista    = Model.ToList();

    int totalVulnerables  = lista.Count(a => a.FueVulnerable);
    int totalCanary       = lista.Count(a => a.CanaryDetectado);
    int totalAiRedteam    = lista.Count(a => a.EsAiRedteam);
}

@* ── Cabecera ── *@
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
    <div class="d-flex align-items-center gap-3">
        <div class="page-header-icon">
            <i class="fa-solid fa-list-ul"></i>
        </div>
        <div>
            <h1 class="page-title">Historial de Ataques</h1>
            <p class="page-subtitle">
                @lista.Count ataques registrados
                @if (proyecto != null)
                {
                    <span class="ms-1">
                        · <strong style="color: var(--color-green);">@proyecto.Nombre</strong>
                    </span>
                }
            </p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Auditoria" asp-action="Benchmark" class="btn-redteam-secondary">
            <i class="fa-solid fa-flask"></i> Benchmark
        </a>
        <a asp-controller="Auditoria" asp-action="Nueva" class="btn-redteam-primary" style="display:none">
            <i class="fa-solid fa-crosshairs"></i> Nuevo Ataque
        </a>
    </div>
</div>

@* ── KPIs rápidas ── *@
@if (lista.Any())
{
    <div class="historial-kpis mb-4">
        <div class="hkpi">
            <div class="hkpi-value">@lista.Count</div>
            <div class="hkpi-label">Total</div>
        </div>
        <div class="hkpi hkpi-danger">
            <div class="hkpi-value">@totalVulnerables</div>
            <div class="hkpi-label">Vulnerables</div>
        </div>
        <div class="hkpi hkpi-canary">
            <div class="hkpi-value">@totalCanary</div>
            <div class="hkpi-label">Canary</div>
        </div>
        <div class="hkpi hkpi-ai">
            <div class="hkpi-value">@totalAiRedteam</div>
            <div class="hkpi-label">AI Red Team</div>
        </div>
        <div class="hkpi @(lista.Count > 0 && totalVulnerables * 100 / lista.Count >= 50 ? "hkpi-danger" : "hkpi-safe")">
            <div class="hkpi-value">
                @(lista.Count > 0 ? (totalVulnerables * 100 / lista.Count) : 0)%
            </div>
            <div class="hkpi-label">Tasa Vuln.</div>
        </div>
    </div>
}

@if (!lista.Any())
{
    <div class="card-redteam">
        <div class="empty-state-redteam" style="min-height: 260px;">
            <i class="fa-solid fa-folder-open fa-3x mb-4" style="opacity:0.2;"></i>
            <p style="font-size: 0.95rem; color: var(--color-text-muted);">
                No hay ataques registrados.
            </p>
            <a asp-controller="Auditoria" asp-action="Benchmark" class="btn-redteam-primary mt-3">
                <i class="fa-solid fa-flask me-1"></i> Lanzar benchmark completo
            </a>
        </div>
    </div>
}
else
{
    @* ── Filtros ── *@
    <div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
        <input type="text" id="filtro-texto" class="input-redteam"
               placeholder="Buscar..." style="max-width: 220px;" />

        <select id="filtro-categoria" class="input-redteam" style="max-width: 150px;">
            <option value="">Categoría</option>
            <option value="clasico">Clásico</option>
            <option value="ai_redteam">AI Red Team</option>
        </select>

        <select id="filtro-tipo" class="input-redteam" style="max-width: 180px;">
            <option value="">Tipo de ataque</option>
            @foreach (var tipo in lista.Select(a => a.TipoAtaque).Distinct().OrderBy(t => t))
            {
                <option value="@tipo">@TFG_Portal.Models.CategoriasAtaque.EtiquetaAmigable(tipo)</option>
            }
        </select>

        <select id="filtro-vulnerable" class="input-redteam" style="max-width: 150px;">
            <option value="">Resultado</option>
            <option value="1">Vulnerables</option>
            <option value="0">Seguros</option>
        </select>

        <select id="filtro-severidad" class="input-redteam" style="max-width: 130px;">
            <option value="">Severidad</option>
            <option value="Alta">Alta</option>
            <option value="Media">Media</option>
            <option value="Baja">Baja</option>
        </select>

        <select id="filtro-canary" class="input-redteam" style="max-width: 150px;">
            <option value="">Canary</option>
            <option value="1">Detectado</option>
            <option value="0">No detectado</option>
        </select>

        <span id="contador-resultados"
              class="label-redteam d-flex align-items-center ms-auto"
              style="font-size: 0.72rem;">
            @lista.Count resultados
        </span>
    </div>

    @* ── Tabla ── *@
    <div class="card-redteam">
        <div class="table-responsive-redteam">
            <table class="table-redteam" id="tabla-historial">
                <thead>
                    <tr>
                        <th style="width:50px;">ID</th>
                        <th>Tipo</th>
                        <th style="width:60px;" class="text-center">BM</th>
                        <th>Prompt</th>
                        <th>Resultado</th>
                        <th>Severidad</th>
                        <th>Payload</th>
                        <th style="width:80px;" class="text-center">Canary</th>
                        <th>Fecha</th>
                        <th style="width:60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ataque in lista)
                    {
                        <tr class="fila-ataque"
                            data-tipo="@ataque.TipoAtaque"
                            data-categoria="@ataque.Categoria"
                            data-vulnerable="@(ataque.FueVulnerable ? "1" : "0")"
                            data-severidad="@(ataque.Severidad ?? "")"
                            data-payload="@(ataque.TipoPayload ?? "")"
                            data-canary="@(ataque.CanaryDetectado ? "1" : "0")"
                            data-texto="@ataque.TipoAtaque.ToLower() @ataque.PromptFragmento.ToLower() @ataque.ModeloIa.ToLower() @(ataque.benchmark_id ?? "")">

                            <td class="col-meta mono">#@ataque.Id</td>

                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <span class="badge-tipo-ataque" style="font-size:0.68rem;">
                                        @TFG_Portal.Models.CategoriasAtaque.EtiquetaAmigable(ataque.TipoAtaque)
                                    </span>
                                    <span class="@ataque.CategoriaBadgeClass" style="font-size:0.58rem; width:fit-content;">
                                        @ataque.CategoriaEtiqueta
                                    </span>
                                </div>
                            </td>

                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(ataque.benchmark_id))
                                {
                                    <span class="benchmark-id-mini" title="Caso benchmark @ataque.benchmark_id">
                                        @ataque.benchmark_id
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--color-text-dim);">—</span>
                                }
                            </td>

                            <td style="max-width: 220px;">
                                <span class="mono prompt-fragment">
                                    @ataque.PromptFragmento
                                </span>
                            </td>

                            <td>
                                @if (ataque.FueVulnerable)
                                { <span class="badge-vulnerable">Vulnerable</span> }
                                else
                                { <span class="badge-seguro">Seguro</span> }
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(ataque.Severidad))
                                { <span class="@ataque.SeveridadBadgeClass">@ataque.Severidad</span> }
                                else
                                { <span style="color:var(--color-text-dim);">—</span> }
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(ataque.TipoPayload))
                                { <span class="@ataque.TipoPayloadBadgeClass">@ataque.TipoPayload</span> }
                                else
                                { <span style="color:var(--color-text-dim);">—</span> }
                            </td>

                            <td class="text-center">
                                <span class="@ataque.CanaryBadgeClass canary-dot-badge"
                                      title="@ataque.CanaryEtiqueta">
                                    <i class="fa-solid @(ataque.CanaryDetectado ? "fa-radiation" : "fa-check")"></i>
                                </span>
                            </td>

                            <td class="col-meta">
                                @ataque.FechaCreacion.ToString("dd/MM/yy HH:mm")
                            </td>

                            <td>
                                <a asp-controller="Auditoria" asp-action="Detalle"
                                   asp-route-id="@ataque.Id"
                                   class="btn-redteam-secondary"
                                   style="padding: 4px 10px; font-size: 0.72rem;">
                                    Ver <i class="fa-solid fa-arrow-right ms-1"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Styles {
<style>
/* ── KPIs ─────────────────────────────────────────────── */
.historial-kpis {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
.hkpi {
    flex: 1;
    min-width: 90px;
    padding: 14px 16px;
    border-radius: var(--radius);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    text-align: center;
}
.hkpi-value {
    font-family: var(--font-code);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    margin-bottom: 4px;
}
.hkpi-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
}
.hkpi-danger { border-color: rgba(220,53,69,0.3); }
.hkpi-danger .hkpi-value { color: #dc3545; }
.hkpi-canary { border-color: rgba(220,53,69,0.2); }
.hkpi-canary .hkpi-value { color: #ff6b6b; }
.hkpi-ai { border-color: rgba(255,170,0,0.25); }
.hkpi-ai .hkpi-value { color: #ffaa00; }
.hkpi-safe .hkpi-value  { color: var(--color-green); }

/* ── Table extras ─────────────────────────────────────── */
.benchmark-id-mini {
    font-family: var(--font-code);
    font-size: 0.62rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 3px;
    background: rgba(167,139,250,0.1);
    border: 1px solid rgba(167,139,250,0.25);
    color: #a78bfa;
    white-space: nowrap;
}
.prompt-fragment {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.canary-dot-badge {
    font-size: 0.75rem;
    padding: 4px 8px !important;
    display: inline-flex;
    align-items: center;
}

/* ── Empty State ── */
.empty-state-redteam {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    text-align: center;
    color: var(--color-text-dim);
}

.empty-state-redteam i {
    color: var(--color-text-dim);
    opacity: 0.4;
    margin-bottom: 12px;
}

.empty-state-redteam p {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
}
</style>
}

@section Scripts {
<script>
(function () {
    const filas    = document.querySelectorAll('.fila-ataque');
    const f = {
        texto:     document.getElementById('filtro-texto'),
        categoria: document.getElementById('filtro-categoria'),
        tipo:      document.getElementById('filtro-tipo'),
        vuln:      document.getElementById('filtro-vulnerable'),
        sev:       document.getElementById('filtro-severidad'),
        canary:    document.getElementById('filtro-canary'),
    };
    const contador = document.getElementById('contador-resultados');

    function filtrar() {
        const texto     = (f.texto?.value || '').toLowerCase();
        const categoria = f.categoria?.value || '';
        const tipo      = f.tipo?.value || '';
        const vuln      = f.vuln?.value || '';
        const sev       = f.sev?.value || '';
        const canary    = f.canary?.value || '';
        let visibles    = 0;

        filas.forEach(fila => {
            const ok =
                (!texto     || fila.dataset.texto.includes(texto)) &&
                (!categoria || fila.dataset.categoria === categoria) &&
                (!tipo      || fila.dataset.tipo === tipo) &&
                (!vuln      || fila.dataset.vulnerable === vuln) &&
                (!sev       || fila.dataset.severidad === sev) &&
                (!canary    || fila.dataset.canary === canary);

            fila.style.display = ok ? '' : 'none';
            if (ok) visibles++;
        });

        if (contador) contador.textContent = visibles + ' resultados';
    }

    Object.values(f).forEach(el => {
        if (el) el.addEventListener(el.tagName === 'INPUT' ? 'input' : 'change', filtrar);
    });
}());
</script>
}
