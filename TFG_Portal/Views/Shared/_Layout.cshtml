@* ============================================================
   _Layout.cshtml — Layout base con sidebar
   AI Red Teaming Platform - TFG Ingeniería Informática
   v6.0 — añade Benchmark y Métricas al sidebar
   ============================================================ *@

@using TFG_Portal.ViewModels
@inject TFG_Portal.Services.IDatabaseService DbService

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction     = ViewContext.RouteData.Values["action"]?.ToString();
    var apiActiva = ViewData["ApiEstado"] as bool? ?? false;
    var apiClase  = apiActiva ? "api-activa" : "api-inactiva";
    var apiTexto  = apiActiva ? "ACTIVA" : "INACTIVA";

    var proyectoActivoId = Context.Session.GetInt32("ProyectoActivoId") ?? 0;
    var todosProyectos   = (await DbService.GetAllProyectosAsync()).ToList();
    var proyectoActivo   = todosProyectos.FirstOrDefault(p => p.Id == proyectoActivoId)
                           ?? todosProyectos.FirstOrDefault();

    // Helper para detectar enlace activo
    bool IsActive(string ctrl, string? action = null) =>
        currentController == ctrl && (action == null || currentAction == action);
}

<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="color-scheme" content="dark" />
    <title>@ViewData["Title"] | AI Red Teaming</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <link rel="stylesheet" href="~/css/redteam.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    @* ── Navbar ── *@
    <nav class="navbar navbar-expand-lg navbar-redteam fixed-top">
        <div class="container-fluid px-4">

            <a class="navbar-brand d-flex align-items-center gap-2"
               asp-controller="Dashboard" asp-action="Index">
                <span class="navbar-logo-icon">
                    <i class="fa-solid fa-shield-halved"></i>
                </span>
                <span class="d-flex flex-column lh-1">
                    <span class="navbar-brand-title">AI RED TEAMING</span>
                    <span class="navbar-brand-subtitle">TFG · Seguridad Ofensiva</span>
                </span>
            </a>

            @if (todosProyectos.Any())
            {
                <div class="proyecto-selector d-none d-lg-flex align-items-center gap-2 ms-4">
                    <i class="fa-solid fa-folder-open"
                       style="color:var(--color-green); opacity:0.7; font-size:0.8rem;"></i>
                    <form asp-controller="Proyecto" asp-action="Seleccionar"
                          method="post" class="d-flex align-items-center gap-2">
                        @Html.AntiForgeryToken()
                        <select name="proyectoId"
                                class="input-redteam input-redteam-sm proyecto-select"
                                onchange="this.form.submit()"
                                title="Proyecto activo">
                            @foreach (var p in todosProyectos)
                            {
                                <option value="@p.Id"
                                        selected="@(p.Id == proyectoActivo?.Id ? "selected" : null)">
                                    @p.Nombre
                                </option>
                            }
                        </select>
                    </form>
                </div>
            }

            <button class="navbar-toggler ms-auto" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false"
                    aria-label="Abrir menú">
                <i class="fa-solid fa-bars" style="color:#00ff41;"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                    <li class="nav-item ms-lg-3">
                        <div id="api-status-container" class="api-status-badge @apiClase">
                            <span class="api-status-dot"></span>
                            <span class="api-status-label">
                                API <span id="api-status-text">@apiTexto</span>
                            </span>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="app-wrapper">

        @* ── Sidebar ── *@
        <aside class="sidebar" id="sidebar">

            <div class="sidebar-project-info">
                <div class="sidebar-project-label">PROYECTO ACTIVO</div>
                <div class="sidebar-project-name">
                    @(proyectoActivo?.Nombre ?? "Sin proyecto")
                </div>
                @if (proyectoActivo != null)
                {
                    <div class="sidebar-project-meta">
                        <i class="fa-solid fa-calendar-days me-1"></i>
                        @proyectoActivo.FechaInicio.ToString("dd/MM/yyyy")
                        <span class="mx-1">·</span>
                        <i class="fa-solid fa-layer-group me-1"></i>
                        @proyectoActivo.TotalAuditorias aud.
                    </div>
                }
            </div>

            <hr class="sidebar-divider" />

            @* ── Navegación principal ── *@
            <nav class="sidebar-nav">
                <div class="sidebar-nav-label">NAVEGACIÓN</div>

                <a class="sidebar-nav-link @(IsActive("Dashboard") ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-gauge"></i>
                    <span>Dashboard</span>
                </a>

                <a class="sidebar-nav-link @(IsActive("Auditoria","Benchmark") ? "active" : "")"
                   asp-controller="Auditoria" asp-action="Benchmark">
                    <i class="fa-solid fa-flask" style="color: @(IsActive("Auditoria","Benchmark") ? "inherit" : "#a78bfa");"></i>
                    <span>Benchmark</span>
                    <span class="sidebar-nav-badge sidebar-nav-badge-purple">10</span>
                </a>

                <a class="sidebar-nav-link @(IsActive("Auditoria","Nueva") ? "active" : "")"
                   asp-controller="Auditoria" asp-action="Nueva">
                    <i class="fa-solid fa-crosshairs"></i>
                    <span>Nuevo Ataque</span>
                </a>

                <a class="sidebar-nav-link @(IsActive("Auditoria","Historial") ? "active" : "")"
                   asp-controller="Auditoria" asp-action="Historial">
                    <i class="fa-solid fa-list-ul"></i>
                    <span>Historial</span>
                </a>
            </nav>

            <hr class="sidebar-divider" />

            @* ── Métricas ── *@
            <nav class="sidebar-nav">
                <div class="sidebar-nav-label">MÉTRICAS</div>

                <a class="sidebar-nav-link @(IsActive("Metricas","Comparativa") ? "active" : "")"
                   asp-controller="Metricas" asp-action="Comparativa">
                    <i class="fa-solid fa-chart-bar"></i>
                    <span>Comparativa</span>
                </a>

                <a class="sidebar-nav-link @(IsActive("Metricas","Ranking") ? "active" : "")"
                   asp-controller="Metricas" asp-action="Ranking">
                    <i class="fa-solid fa-trophy"></i>
                    <span>Ranking Robustez</span>
                </a>

                <a class="sidebar-nav-link @(IsActive("Metricas","Evolucion") ? "active" : "")"
                   asp-controller="Metricas" asp-action="Evolucion">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Evolución</span>
                </a>

                <a class="sidebar-nav-link @(IsActive("Metricas","Exportar") ? "active" : "")"
                   asp-controller="Metricas" asp-action="Exportar">
                    <i class="fa-solid fa-file-csv"></i>
                    <span>Exportar CSV</span>
                </a>
            </nav>

            <hr class="sidebar-divider" />

            @* ── Proyectos ── *@
            <div class="sidebar-nav">
                <div class="sidebar-nav-label">PROYECTOS</div>

                @foreach (var p in todosProyectos)
                {
                    <form asp-controller="Proyecto" asp-action="Seleccionar"
                          method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="proyectoId" value="@p.Id" />
                        <button type="submit"
                                class="sidebar-proyecto-item @(p.Id == proyectoActivo?.Id ? "active" : "")">
                            <i class="fa-solid fa-folder@(p.Id == proyectoActivo?.Id ? "-open" : "")"></i>
                            <span class="sidebar-proyecto-nombre">@p.Nombre</span>
                            <span class="sidebar-proyecto-count">@p.TotalAuditorias</span>
                        </button>
                    </form>
                }

                <a class="sidebar-nav-link sidebar-nav-new"
                   asp-controller="Proyecto" asp-action="Crear">
                    <i class="fa-solid fa-plus"></i>
                    <span>Nuevo Proyecto</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <span class="sidebar-version">v6.0 · TFG 2026</span>
            </div>

        </aside>

        @* ── Contenido principal ── *@
        <main class="main-content">
            <div class="container-fluid px-4">

                @if (ViewData["Error"] != null)
                {
                    <div class="alert-redteam alert-redteam-danger mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>
                        @ViewData["Error"]
                    </div>
                }

                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="footer-redteam">
        <div class="container-fluid px-4">
            <span>
                <i class="fa-solid fa-shield-halved me-1" style="color:#00ff41; opacity:0.5;"></i>
                AI Red Teaming Platform
                <span class="text-muted mx-2">·</span>
                TFG Ingeniería Informática
                <span class="text-muted mx-2">·</span>
                @DateTime.Now.Year
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmOJFBBwBbQ6zHoAQN/UxG3LLHEgR"
            crossorigin="anonymous"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('pre code').forEach(block => hljs.highlightElement(block));
        });
    </script>

    @* ── Polling del estado de la API ── *@
    <script>
    (function () {
        const container  = document.getElementById('api-status-container');
        const statusText = document.getElementById('api-status-text');

        function setStatus(activa) {
            if (!container || !statusText) return;
            container.classList.toggle('api-activa',  activa);
            container.classList.toggle('api-inactiva', !activa);
            statusText.textContent = activa ? 'ACTIVA' : 'INACTIVA';
        }

        async function check() {
            try {
                const r = await fetch('/Dashboard/ApiEstado', {
                    headers: { Accept: 'application/json' },
                    signal: AbortSignal.timeout(5000)
                });
                const d = r.ok ? await r.json() : null;
                setStatus(d?.activo === true);
            } catch { setStatus(false); }
        }

        check();
        setInterval(check, 30000);
    }());
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
