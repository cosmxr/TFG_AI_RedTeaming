@* ============================================================
   _ValidationScriptsPartial.cshtml
   Scripts de validación client-side para formularios Razor.
   Se incluye con @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
   en las vistas que tengan formularios con DataAnnotations.
   ============================================================ *@

@* jQuery — requerido por Unobtrusive Validation *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
        integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g=="
        crossorigin="anonymous"></script>

@* jQuery Validation — lógica de validación *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"
        integrity="sha512-KFHXdr2oObHKI9w4Hv1XPKc898mE4kgYx58oqsc/JqqdLMDI4YjOLzom+EMlW8HFUd0QfjfAvxSL6sEq/a42A=="
        crossorigin="anonymous"></script>

@* jQuery Unobtrusive Validation — integración con ASP.NET Core MVC *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"
        integrity="sha512-xq+Vm4jJ9QNkBTEbcRpCT/oBoR8RbRBJVWAXWEJFJggRlCv1fTCBj9tJhTfLkZVBONOWCJP4YXkjNHa3k2mQ=="
        crossorigin="anonymous"></script>